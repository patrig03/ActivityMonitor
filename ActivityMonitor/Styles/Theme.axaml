<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ========= RESOURCES ========= -->
  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/Styles/Colors.axaml"/>
        <ResourceInclude Source="/Styles/Spacing.axaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Styles.Resources>

  <!-- ========= GLOBAL TEXT ========= -->
  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
  </Style>

  <!-- ========= CONTROL STYLES ========= -->
  <StyleInclude Source="/Styles/Controls/ButtonStyles.axaml"/>
  <StyleInclude Source="/Styles/Controls/DataGridStyles.axaml"/>
  <StyleInclude Source="/Styles/Controls/InputStyles.axaml"/>
  <StyleInclude Source="/Styles/Controls/ExpanderStyles.axaml"/>

</Styles>
