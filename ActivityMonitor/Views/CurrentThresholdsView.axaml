<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ActivityMonitor.Views.CurrentThresholdsView"
             x:DataType="viewModels:InterventionsViewModel">

  
  
  <UserControl.Styles>
    <Style Selector="DataGrid">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="GridLinesVisibility" Value="All"/>
      <Setter Property="RowBackground" Value="#222222"/>
      <Setter Property="HorizontalGridLinesBrush" Value="#30FFFFFF"/>
      <Setter Property="VerticalGridLinesBrush" Value="#30FFFFFF"/>
    </Style>
        
    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#ffffff"/>
      <Setter Property="BorderThickness" Value="0,0,0,2"/>
      <Setter Property="BorderBrush" Value="#30FFFFFF"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
        
    <Style Selector="DataGridColumnHeader.center">
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
        
    <Style Selector="DataGridCell">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>
        
    <Style Selector="DataGridCell.center">
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
        
    <Style Selector="DataGridCell:pointerover">
      <Setter Property="Background" Value="#1A3A6DA0"/>
    </Style>
        
    <Style Selector="DataGridRow:selected">
      <Setter Property="Background" Value="#2A3A6DA0"/>
    </Style>
  </UserControl.Styles>
  
  <DataGrid ItemsSource="{Binding Data}"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            SelectionMode="Single"
            CanUserResizeColumns="True"
            CanUserSortColumns="True"
            FontSize="13"
            Foreground="#E0E0E0">


    <DataGrid.Columns>
      <DataGridTextColumn Header="Id"
                          Binding="{Binding threshold.Id}"
                          Width="Auto"
                          CanUserSort="True"/>
                          
      <DataGridTextColumn Header="CategoryId"
                          Binding="{Binding threshold.CategoryId}"
                          Width="Auto"
                          CanUserSort="True"/>
                          
      <DataGridTextColumn Header="Active"
                          Binding="{Binding threshold.Active}"
                          Width="Auto"
                          CanUserSort="True">
      </DataGridTextColumn>
    
      <DataGridTextColumn Header="InterventionType"
                          Binding="{Binding threshold.InterventionType}"
                          Width="Auto"
                          CanUserSort="True">
      </DataGridTextColumn>
      
      <DataGridTextColumn Header="DailyLimit"
                          Binding="{Binding threshold.DailyLimit}"
                          Width="Auto"
                          CanUserSort="True">
      </DataGridTextColumn>
      
      <DataGridTextColumn Header="WeeklyLimit"
                          Binding="{Binding threshold.WeeklyLimit}"
                          Width="Auto"
                          CanUserSort="True">
      </DataGridTextColumn>
        
    </DataGrid.Columns>
  </DataGrid>
</UserControl>
