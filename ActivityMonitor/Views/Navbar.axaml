<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ActivityMonitor.Views.Navbar">

    <!-- ========= SIDE NAVIGATION ========= -->
    <Border Background="#101010" Padding="0,24,0,24">
        <StackPanel Margin="16,0,8,0" Spacing="8">


            <!-- Navigation Items -->
            <StackPanel Spacing="4">
                <Button Content="Dashboard"
                        CornerRadius="8"
                        Background="#555555"
                        Foreground="White"
                        Padding="12,10"
                        HorizontalAlignment="Stretch"
                        Click="Button_OnClick"
                        FontWeight="SemiBold"/>

                <Button Content="Reports"
                        CornerRadius="8"
                        Background="Transparent"
                        Foreground="#C7D1E0"
                        Padding="12,10"
                        HorizontalAlignment="Stretch"
                        FontWeight="Medium"
                        Click="Button_OnClick"
                        Classes="nav-button"/>

                <Button Content="Settings"
                        CornerRadius="8"
                        Background="Transparent"
                        Foreground="#C7D1E0"
                        Padding="12,10"
                        HorizontalAlignment="Stretch"
                        FontWeight="Medium"
                        Click="Button_OnClick"
                        Classes="nav-button"/>

            </StackPanel>

            <!-- Status Panel -->
            <Border Background="#191919"
                    CornerRadius="8"
                    Margin="0,24,0,0"
                    Padding="16,12">
                <StackPanel Spacing="4">
                    <TextBlock Text="STATUS"
                               Foreground="#7C7C7C"
                               FontSize="11"
                               FontWeight="Medium"
                               LetterSpacing="0.5"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#6DFF9C"/>
                        <TextBlock Text="Monitoring Active"
                                   Foreground="#EAF1FF"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                    </StackPanel>
                    
                    <TextBlock Text="Last updated: 2 min ago"
                               Foreground="#7C879C"
                               FontSize="11"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
