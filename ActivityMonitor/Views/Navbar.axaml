<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ActivityMonitor.Views.Navbar">

  <Border Classes="panel-card"
          Padding="16"
          MinWidth="260">
    <StackPanel Spacing="10">
      <TextBlock Text="ActivityMonitor"
                 FontSize="22"
                 FontWeight="Bold"
                 Foreground="{StaticResource BrushTextSecondary}"/>
      <TextBlock Text="Panou principal"
                 Foreground="{StaticResource BrushTextSubtle}"
                 Margin="0,0,0,10"/>

      <Border Classes="panel-card panel-card--muted"
              Margin="0,0,0,16"
              Padding="16,14">
        <StackPanel Spacing="4">
          <TextBlock Text="STARE"
                     Foreground="{StaticResource BrushTextSubtle}"
                     FontSize="11"
                     FontWeight="Medium"
                     LetterSpacing="0.5"/>

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Ellipse Name="StatusIndicator"
                     Width="8"
                     Height="8"
                     Fill="{StaticResource BrushAccentSuccess}"/>
            <TextBlock Name="StatusText"
                       Text="Monitorizare activa"
                       Foreground="{StaticResource BrushTextSecondary}"
                       FontWeight="SemiBold"
                       FontSize="14"/>
          </StackPanel>

          <TextBlock Name="StatusUpdateTime"
                     Text="Ultima actualizare: acum câteva secunde"
                     Foreground="{StaticResource BrushTextMuted}"
                     FontSize="11"
                     Margin="0,4,0,0"/>

          <Button Name="StartBackendButton"
                  Classes="action-button primary-button"
                  Content="Porneste"
                  Click="BackendStatus_OnClick"
                  Margin="0,10,0,0"/>

          <TextBlock Name="StatusActionMessage"
                     IsVisible="False"
                     Foreground="{StaticResource BrushAccentWarning}"
                     FontSize="11"
                     Margin="0,8,0,0"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <StackPanel Name="NavItems" Spacing="6">
        <Button Content="Dashboard"
                Name="DashboardButton"
                Tag="Dashboard"
                Click="Button_OnClick"
                Classes="nav-button"/>

        <Button Content="Rapoarte"
                Tag="Reports"
                Click="Button_OnClick"
                Classes="nav-button"/>

        <Button Content="Browser"
                Tag="Browser"
                Click="Button_OnClick"
                Classes="nav-button"/>

        <Button Content="Interventii"
                Tag="Interventions"
                Click="Button_OnClick"
                Classes="nav-button"/>

        <Button Content="Dispozitive"
                Tag="Devices"
                Click="Button_OnClick"
                Classes="nav-button"/>

        <Button Content="Categorii"
                Tag="Categories"
                Click="Button_OnClick"
                Classes="nav-button"/>
        
        <Button Content="Setari"
                Tag="Settings"
                Click="Button_OnClick"
                Classes="nav-button"/>
      </StackPanel>

    </StackPanel>
  </Border>
</UserControl>
