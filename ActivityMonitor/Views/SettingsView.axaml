<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             x:DataType="viewModels:SettingsViewModel"
             x:Class="ActivityMonitor.Views.SettingsView">

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="20" Spacing="18">

      <Border Classes="page-hero">
        <Grid ColumnDefinitions="*,340" ColumnSpacing="16">
          <StackPanel Spacing="10">
            <TextBlock Text="Setări" Classes="page-title"/>
            <TextBlock Text="Ajusteaza ritmul monitorizarii, verifica ce stocheaza colectorul local si salveaza valori implicite sigure pentru clientul desktop."
                       Classes="page-subtitle"/>
            <WrapPanel Orientation="Horizontal">
              <Border Classes="chip chip--overlay" Margin="0,10,10,0">
                <TextBlock Text="{Binding MonitoringSummary}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
              <Border Classes="chip chip--overlay" Margin="0,10,10,0">
                <TextBlock Text="{Binding IntervalProfile}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
              <Border Classes="chip chip--overlay" Margin="0,10,0,0">
                <TextBlock Text="{Binding LastSavedLabel}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
            </WrapPanel>
          </StackPanel>

          <Border Grid.Column="1"
                  Classes="panel-card panel-card--overlay"
                  Padding="18">
            <StackPanel Spacing="12">
              <TextBlock Text="Stare" Foreground="{StaticResource BrushTextMuted}"/>
              <TextBlock Text="{Binding SaveStatus}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource BrushTextSecondary}" TextWrapping="Wrap"/>
              <TextBlock Text="{Binding ValidationMessage}" Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap"/>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Command="{Binding SaveCommand}"
                        Classes="action-button success-button"
                        Content="Salveaza"/>
                <Button Grid.Column="1"
                        Command="{Binding ReloadCommand}"
                        Classes="action-button subtle-button"
                        Content="Reincarca"/>
              </Grid>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Grid ColumnDefinitions="1.2*,0.8*" ColumnSpacing="18">
        <StackPanel Spacing="18">

          <Border Classes="panel-card">
            <StackPanel Spacing="16">
              <TextBlock Text="Ritm de esantionare" Classes="section-title"/>
              <TextBlock Text="Acest interval controleaza cat de des colectorul reevalueaza ferestrele active si regulile de interventie."
                         Classes="section-subtitle"/>

              <WrapPanel Orientation="Horizontal">
                <Button Margin="0,0,10,10"
                        Command="{Binding UseHighPrecisionPresetCommand}"
                        Classes="action-button subtle-button"
                        Content="5s precizie ridicata"/>
                <Button Margin="0,0,10,10"
                        Command="{Binding UseBalancedPresetCommand}"
                        Classes="action-button success-button"
                        Content="10s echilibrat"/>
                <Button Margin="0,0,0,10"
                        Command="{Binding UseLowOverheadPresetCommand}"
                        Classes="action-button warning-button"
                        Content="30s consum redus"/>
              </WrapPanel>

              <Grid ColumnDefinitions="220,*" ColumnSpacing="16">
                <StackPanel Spacing="8">
                  <TextBlock Text="Interval de reîmprospătare (secunde)" Classes="field-label"/>
                  <TextBox Text="{Binding RefreshIntervalSeconds}"
                           Watermark="10"
                           FontSize="18"/>
                  <TextBlock Text="Interval acceptat: 1 până la 600 secunde." Classes="section-subtitle"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Classes="panel-card panel-card--muted"
                        Padding="16">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Impact estimat" Classes="field-label"/>
                    <TextBlock Text="{Binding IntervalImpact}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BrushTextSecondary}"/>
                    <TextBlock Text="{Binding ValidationMessage}" Classes="section-subtitle"/>
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="panel-card">
            <StackPanel Spacing="16">
              <TextBlock Text="Persistenta si rulare" Classes="section-title"/>

              <StackPanel Spacing="8">
                <TextBlock Text="Cale baza de date" Classes="field-label"/>
                <TextBox Text="{Binding DatabasePath}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"/>
              </StackPanel>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <StackPanel Spacing="8">
                  <TextBlock Text="Stare baza de date" Classes="field-label"/>
                  <Border Classes="panel-card panel-card--muted"
                          Padding="14">
                    <TextBlock Text="{Binding DatabaseStatus}" Foreground="{StaticResource BrushTextPrimary}" TextWrapping="Wrap"/>
                  </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="8">
                  <TextBlock Text="Mutex serviciu" Classes="field-label"/>
                  <TextBox Text="{Binding ServiceMutexName}"
                           IsReadOnly="True"/>
                </StackPanel>
              </Grid>

              <StackPanel Spacing="8">
                <TextBlock Text="Server sincronizare" Classes="field-label"/>
                <TextBox Text="{Binding SyncServerAddress}"
                         Watermark="Ex: localhost:5000 sau https://sync.example"/>
              </StackPanel>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <StackPanel Spacing="8">
                  <TextBlock Text="Email SyncServer" Classes="field-label"/>
                  <TextBox Text="{Binding SyncEmail}"
                           Watermark="user@example.com"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="8">
                  <TextBlock Text="Parola SyncServer" Classes="field-label"/>
                  <TextBox Text="{Binding SyncPassword}"
                           Watermark="Introdu parola contului server"/>
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Command="{Binding CheckSyncServerCommand}"
                        Classes="action-button subtle-button"
                        Content="Testeaza serverul"/>
                <Button Grid.Column="1"
                        Command="{Binding LoginSyncCommand}"
                        Classes="action-button success-button"
                        Content="Conecteaza-te"/>
                <Button Grid.Column="2"
                        Command="{Binding RegisterSyncCommand}"
                        Classes="action-button warning-button"
                        Content="Creeaza cont"/>
                <Button Grid.Column="3"
                        Command="{Binding ClearSyncSessionCommand}"
                        Classes="action-button subtle-button"
                        Content="Sterge sesiunea"/>
              </Grid>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <Border Classes="panel-card panel-card--muted"
                        Padding="14">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Autentificare" Classes="field-label"/>
                    <TextBlock Text="{Binding SyncAuthStatus}" Foreground="{StaticResource BrushTextPrimary}" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Classes="panel-card panel-card--muted"
                        Padding="14">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Dispozitiv si serverTime" Classes="field-label"/>
                    <TextBlock Text="{Binding SyncDeviceStatus}" Foreground="{StaticResource BrushTextPrimary}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding SyncServerTimeStatus}" Classes="section-subtitle" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
              </Grid>

              <StackPanel Spacing="8">
                <TextBlock Text="Preview endpointuri" Classes="field-label"/>
                <Border Classes="panel-card panel-card--muted"
                        Padding="14">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Health, auth, devices si sync" Classes="field-label"/>
                    <TextBlock Text="{Binding SyncEndpointPreview}" Foreground="{StaticResource BrushTextPrimary}" TextWrapping="Wrap"/>
                    <TextBlock Text="Clientul verifica health, obtine un token prin /api/auth/login sau /api/auth/register, inregistreaza dispozitivul prin /api/devices si sincronizeaza datele prin POST /api/sync."
                               Classes="section-subtitle"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1" Spacing="18">
          <Border Classes="panel-card panel-card--warning">
            <StackPanel Spacing="16">
              <TextBlock Text="Date principale" Classes="section-title"/>

              <Border Classes="panel-card panel-card--muted" Padding="16">
                <StackPanel Spacing="6">
                  <TextBlock Text="Acoperire praguri" Classes="metric-label"/>
                  <TextBlock Text="{Binding ThresholdCoverage}" Foreground="{StaticResource BrushTextSecondary}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>

              <Border Classes="panel-card panel-card--muted" Padding="16">
                <StackPanel Spacing="6">
                  <TextBlock Text="Acoperire activitate" Classes="metric-label"/>
                  <TextBlock Text="{Binding ActivityCoverage}" Foreground="{StaticResource BrushTextSecondary}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>

              <Border Classes="panel-card panel-card--muted" Padding="16">
                <StackPanel Spacing="6">
                  <TextBlock Text="Istoric interventii" Classes="metric-label"/>
                  <TextBlock Text="{Binding InterventionCoverage}" Foreground="{StaticResource BrushTextSecondary}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>

              <Border Classes="panel-card panel-card--muted" Padding="16">
                <StackPanel Spacing="6">
                  <TextBlock Text="Captura browser" Classes="metric-label"/>
                  <TextBlock Text="{Binding BrowserCoverage}" Foreground="{StaticResource BrushTextSecondary}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="panel-card">
            <StackPanel Spacing="14">
              <TextBlock Text="Gestionarea modificarilor" Classes="section-title"/>
              <TextBlock Text="Folosește profilul implicit dacă vrei date de trend fiabile fără să încarci stocarea. Treci la 5 secunde doar dacă limitele de intervenție au nevoie de sincronizare mai strictă."
                         Classes="section-subtitle"/>

              <Button Command="{Binding ResetDefaultsCommand}"
                      Classes="action-button subtle-button"
                      Content="Resetează intervalul la implicit"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>

    </StackPanel>
  </ScrollViewer>
</UserControl>
