<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Name="Root"
             x:Class="ActivityMonitor.Views.CurrentThresholdsView"
             x:DataType="viewModels:InterventionsViewModel">

  <DataGrid ItemsSource="{Binding ThresholdRows}"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            SelectionMode="Single"
            CanUserResizeColumns="True"
            CanUserSortColumns="True"
            FontSize="13"
            MinHeight="260">
    <DataGrid.Columns>
      <DataGridTextColumn Header="Id" Binding="{Binding Threshold.Id}" Width="Auto"/>
      <DataGridTextColumn Header="Tinta" Binding="{Binding TargetName}" Width="2*"/>
      <DataGridTextColumn Header="Tip tinta" Binding="{Binding Threshold.TargetType}" Width="Auto"/>
      <DataGridTextColumn Header="Activ" Binding="{Binding Threshold.Active}" Width="Auto"/>
      <DataGridTextColumn Header="Interventie" Binding="{Binding Threshold.InterventionType}" Width="Auto"/>
      <DataGridTextColumn Header="Limita" Binding="{Binding LimitSummary}" Width="Auto"/>

      <DataGridTemplateColumn Header="" Width="Auto">
        <DataGridTemplateColumn.CellTemplate>
          <DataTemplate>
            <Button Content="Editeaza"
                    Classes="action-button subtle-button"
                    Command="{Binding #Root.DataContext.EditRowCommand}"
                    CommandParameter="{Binding}"
                    CornerRadius="10"
                    Padding="10,6"/>
          </DataTemplate>
        </DataGridTemplateColumn.CellTemplate>
      </DataGridTemplateColumn>

      <DataGridTemplateColumn Header="" Width="Auto">
        <DataGridTemplateColumn.CellTemplate>
          <DataTemplate>
            <Button Content="Sterge"
                    Classes="action-button warning-button"
                    Command="{Binding #Root.DataContext.DeleteCommand}"
                    CommandParameter="{Binding}"
                    CornerRadius="10"
                    Padding="10,6"/>
          </DataTemplate>
        </DataGridTemplateColumn.CellTemplate>
      </DataGridTemplateColumn>
    </DataGrid.Columns>
  </DataGrid>
</UserControl>
