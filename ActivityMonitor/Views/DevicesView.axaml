<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             x:Class="ActivityMonitor.Views.DevicesView"
             x:DataType="viewModels:DevicesViewModel">

  <UserControl.Resources>
    <DataTemplate x:Key="DeviceCardTemplate" DataType="viewModels:AccountDeviceRow">
      <Border Classes="panel-card panel-card--muted"
              Margin="0,0,0,14"
              Padding="18">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="6">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding Name}"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrushTextSecondary}"/>
                <Border IsVisible="{Binding IsCurrentDevice}"
                        Classes="chip chip--success"
                        Padding="10,4">
                  <TextBlock Text="Acest dispozitiv"
                             Foreground="{StaticResource BrushTextSecondary}"
                             FontSize="11"
                             FontWeight="Bold"/>
                </Border>
              </StackPanel>
              <TextBlock Text="{Binding DeviceType}" Foreground="{StaticResource BrushTextMuted}" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding ActivitySummary}" Foreground="{StaticResource BrushTextPrimary}" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="8" HorizontalAlignment="Right">
              <Border Classes="chip chip--overlay" Padding="10,4">
                <TextBlock Text="{Binding StatusChip}" Foreground="{StaticResource BrushTextOnSoft}" FontSize="11" FontWeight="Bold"/>
              </Border>
              <Border Classes="chip" Padding="10,4">
                <TextBlock Text="{Binding TrustChip}" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" FontWeight="Bold"/>
              </Border>
            </StackPanel>
          </Grid>

          <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
            <Border Classes="panel-card panel-card--overlay" Padding="14">
              <StackPanel Spacing="4">
                <TextBlock Text="Platforma" Classes="metric-label"/>
                <TextBlock Text="{Binding Platform}" Foreground="{StaticResource BrushTextSecondary}" FontWeight="SemiBold"/>
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="panel-card panel-card--overlay" Padding="14">
              <StackPanel Spacing="4">
                <TextBlock Text="Ultima activitate" Classes="metric-label"/>
                <TextBlock Text="{Binding LastSeenLabel}" Foreground="{StaticResource BrushTextSecondary}" FontWeight="SemiBold"/>
              </StackPanel>
            </Border>
          </Grid>

          <TextBlock Text="{Binding VersionSummary}" Foreground="{StaticResource BrushTextMuted}"/>

          <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
            <Button Grid.Column="0"
                    CommandParameter="{Binding}"
                    Classes="action-button subtle-button"
                    Content="Detalii"/>

            <Button Grid.Column="1"
                    CommandParameter="{Binding}"
                    Classes="action-button success-button"
                    Content="{Binding TrustActionLabel}"/>

            <Button Grid.Column="2"
                    CommandParameter="{Binding}"
                    Classes="action-button warning-button"
                    Content="{Binding ActionLabel}"/>
          </Grid>
        </StackPanel>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="20" Spacing="18">

      <Border Classes="page-hero">
        <Grid ColumnDefinitions="*,340" ColumnSpacing="18">
          <StackPanel Spacing="10">
            <TextBlock Text="Dispozitive" Classes="page-title"/>
            <TextBlock Text="{Binding PageSubtitle}" Classes="page-subtitle"/>

            <WrapPanel Orientation="Horizontal">
              <Border Classes="chip chip--overlay" Margin="0,10,10,0">
                <TextBlock Text="{Binding AccountLabel}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
              <Border Classes="chip chip--overlay" Margin="0,10,10,0">
                <TextBlock Text="{Binding CurrentDeviceLabel}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
              <Border Classes="chip chip--overlay" Margin="0,10,10,0">
                <TextBlock Text="{Binding LastRefreshLabel}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
              <Border Classes="chip chip--overlay" Margin="0,10,0,0">
                <TextBlock Text="{Binding LastServerSyncLabel}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
            </WrapPanel>
          </StackPanel>

          <Border Grid.Column="1"
                  Classes="panel-card panel-card--overlay"
                  Padding="18">
            <StackPanel Spacing="12">
              <TextBlock Text="Stare cont" Foreground="{StaticResource BrushTextMuted}"/>
              <TextBlock Text="{Binding DeviceStatus}"
                         FontSize="20"
                         FontWeight="Bold"
                         Foreground="{StaticResource BrushTextSecondary}"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding CurrentDeviceDetail}"
                         Foreground="{StaticResource BrushTextPrimary}"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding SyncServerLabel}"
                         Foreground="{StaticResource BrushTextMuted}"
                         TextWrapping="Wrap"/>

              <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Command="{Binding RegisterCurrentDeviceCommand}"
                        Classes="action-button success-button"
                        Content="Inregistreaza desktopul"/>
                <Button Grid.Column="1"
                        Command="{Binding SyncWithServerCommand}"
                        Classes="action-button primary-button"
                        Content="Sincronizeaza cu serverul"/>
                <Button Grid.Column="2"
                        Command="{Binding RefreshCommand}"
                        Classes="action-button subtle-button"
                        Content="Reincarca"/>
              </Grid>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <WrapPanel Orientation="Horizontal">
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Total dispozitive" Classes="metric-label"/>
            <TextBlock Text="{Binding TotalDevices}" Classes="metric-value"/>
            <TextBlock Text="Inregistrate pe cont" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Active" Classes="metric-label"/>
            <TextBlock Text="{Binding ActiveDevices}" Classes="metric-value"/>
            <TextBlock Text="Cu acces valid" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="De incredere" Classes="metric-label"/>
            <TextBlock Text="{Binding TrustedDevices}" Classes="metric-value"/>
            <TextBlock Text="Nu necesita review" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card" Margin="0,0,0,14">
          <StackPanel Spacing="6">
            <TextBlock Text="Revocate" Classes="metric-label"/>
            <TextBlock Text="{Binding RevokedDevices}" Classes="metric-value"/>
            <TextBlock Text="Scoase din acces" Classes="metric-detail"/>
          </StackPanel>
        </Border>
      </WrapPanel>

      <Grid ColumnDefinitions="1.2*,0.8*" ColumnSpacing="18">
        <StackPanel Spacing="18">

          <Border Classes="panel-card panel-card--success">
            <StackPanel Spacing="14">
              <TextBlock Text="Dispozitive conectate" Classes="section-title"/>
              <TextBlock Text="Monitorizeaza dispozitivele care au acces la cont si actioneaza rapid cand unul nu mai trebuie sa fie conectat."
                         Classes="section-subtitle"/>

              <ItemsControl ItemsSource="{Binding Devices}" ItemTemplate="{StaticResource DeviceCardTemplate}"/>
            </StackPanel>
          </Border>

          <Border Classes="panel-card panel-card--warning">
            <StackPanel Spacing="16">
              <TextBlock Text="Adauga un dispozitiv" Classes="section-title"/>
              <TextBlock Text="Inregistreaza manual un dispozitiv companion pentru a-i urmari accesul si a-l putea revoca din acelasi loc."
                         Classes="section-subtitle"/>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <StackPanel Spacing="8">
                  <TextBlock Text="Nume dispozitiv" Classes="field-label"/>
                  <TextBox Text="{Binding NewDeviceName}"
                           Watermark="Ex: Laptop birou"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="8">
                  <TextBlock Text="Tip" Classes="field-label"/>
                  <ComboBox ItemsSource="{Binding AvailableDeviceTypes}"
                            SelectedItem="{Binding NewDeviceType}"/>
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <StackPanel Spacing="8">
                  <TextBlock Text="Platforma" Classes="field-label"/>
                  <TextBox Text="{Binding NewDevicePlatform}"
                           Watermark="Windows, macOS, Android..."/>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="8">
                  <TextBlock Text="Versiune aplicatie" Classes="field-label"/>
                  <TextBox Text="{Binding NewDeviceVersion}"
                           Watermark="Optional"/>
                </StackPanel>
              </Grid>

              <Button Command="{Binding AddDeviceCommand}"
                      Classes="action-button warning-button"
                      Content="Adauga dispozitivul"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1" Spacing="18">
          <Border Classes="panel-card">
            <StackPanel Spacing="14">
              <TextBlock Text="Panou de administrare"
                         Classes="section-title"/>

              <StackPanel IsVisible="{Binding HasSelectedDevice}" Spacing="14">
                <TextBlock Text="{Binding SelectedDeviceState}"
                           Foreground="{StaticResource BrushTextSecondary}"
                           FontWeight="SemiBold"
                           FontSize="16"/>
                <TextBlock Text="{Binding SelectedDeviceTimeline}"
                           Foreground="{StaticResource BrushTextMuted}"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding SelectedDeviceTrust}"
                           Foreground="{StaticResource BrushTextMuted}"
                           TextWrapping="Wrap"/>

                <StackPanel Spacing="8">
                  <TextBlock Text="Nume dispozitiv" Classes="field-label"/>
                  <TextBox Text="{Binding SelectedDeviceName}"/>
                </StackPanel>

                <StackPanel Spacing="8">
                  <TextBlock Text="Tip dispozitiv" Classes="field-label"/>
                  <ComboBox ItemsSource="{Binding AvailableDeviceTypes}"
                            SelectedItem="{Binding SelectedDeviceType}"/>
                </StackPanel>

                <StackPanel Spacing="8">
                  <TextBlock Text="Platforma" Classes="field-label"/>
                  <TextBox Text="{Binding SelectedDevicePlatform}"/>
                </StackPanel>

                <StackPanel Spacing="8">
                  <TextBlock Text="Versiune aplicatie" Classes="field-label"/>
                  <TextBox Text="{Binding SelectedDeviceVersion}"/>
                </StackPanel>

                <StackPanel Spacing="8">
                  <TextBlock Text="Amprenta dispozitiv" Classes="field-label"/>
                  <TextBox Text="{Binding SelectedDeviceFingerprint}"
                           IsReadOnly="True"/>
                </StackPanel>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                  <Button Grid.Column="0"
                          Command="{Binding SaveSelectedDeviceCommand}"
                          Classes="action-button success-button"
                          Content="Salveaza"/>
                  <Button Grid.Column="1"
                          Command="{Binding ClearSelectionCommand}"
                          Classes="action-button subtle-button"
                          Content="Goleste selectia"/>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                  <Button Grid.Column="0"
                          Command="{Binding ToggleTrustedCommand}"
                          Classes="action-button success-button"
                          Content="{Binding SelectedTrustActionLabel}"/>
                  <Button Grid.Column="1"
                          Command="{Binding ToggleDeviceStatusCommand}"
                          Classes="action-button warning-button"
                          Content="{Binding SelectedStatusActionLabel}"/>
                </Grid>
              </StackPanel>

              <Border IsVisible="{Binding NoSelectedDevice}"
                      Classes="panel-card panel-card--muted"
                      Padding="16">
                <StackPanel Spacing="8">
                  <TextBlock Text="Niciun dispozitiv selectat"
                             Foreground="{StaticResource BrushTextSecondary}"
                             FontWeight="SemiBold"
                             FontSize="16"/>
                  <TextBlock Text="Alege un card din lista pentru a edita numele, platforma sau pentru a revoca rapid accesul."
                             Foreground="{StaticResource BrushTextMuted}"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
