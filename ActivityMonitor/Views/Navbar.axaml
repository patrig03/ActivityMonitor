<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ActivityMonitor.Views.Navbar">

  <UserControl.Resources>
    <ControlTheme x:Key="NavButtonTheme" TargetType="Button">
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Foreground" Value="#C7D1E0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/>

      <Setter Property="Template">
        <ControlTemplate TargetType="Button">
          <Border Name="PART_Border"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}">
            <ContentPresenter Name="PART_ContentPresenter"
                              Margin="{TemplateBinding Padding}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              RecognizesAccessKey="True"/>
          </Border>
        </ControlTemplate>
      </Setter>
    </ControlTheme>
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- Base theme applied via Theme=... -->
    <Style Selector="Button.nav-button">
      <Setter Property="Theme" Value="{StaticResource NavButtonTheme}"/>
            
    </Style>

    <Style Selector="Button.nav-button:pointerover">
      <Setter Property="Background" Value="#222222"/>
      <Setter Property="BorderBrush" Value="#2A2A2A"/>
      <Setter Property="Foreground" Value="#EAF1FF"/>
    </Style>

    <Style Selector="Button.nav-button:pressed">
      <Setter Property="Background" Value="#151515"/>
      <Setter Property="BorderBrush" Value="#3A3A3A"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.nav-button.nav-button--active">
      <Setter Property="Background" Value="#555555"/>
      <Setter Property="BorderBrush" Value="#6A6A6A"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
  </UserControl.Styles>

    <!-- ========= SIDE NAVIGATION ========= -->
    <Border Background="#101010" Padding="4,24,4,24">
      <StackPanel Margin="16,0,8,0" Spacing="8">

            
        <!-- Status Panel -->
        <Border Background="#191919"
                CornerRadius="8"
                Margin="0,0,0,24"
                Padding="16,12">
          <StackPanel Spacing="4">
            <TextBlock Text="STATUS"
                       Foreground="#7C7C7C"
                       FontSize="11"
                       FontWeight="Medium"
                       LetterSpacing="0.5"/>

            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <Ellipse Width="8" Height="8" Fill="#6DFF9C"/>
              <TextBlock Text="Monitoring Active"
                         Foreground="#EAF1FF"
                         FontWeight="SemiBold"
                         FontSize="14"/>
            </StackPanel>

            <TextBlock Text="Last updated: 2 min ago"
                       Foreground="#7C879C"
                       FontSize="11"
                       Margin="0,4,0,0"/>
          </StackPanel>
        </Border>
            
            
        <!-- Navigation Items -->
        <StackPanel Name="NavItems" Spacing="4">
          <!-- Mark the current item as active via a class -->
          <Button Content="Dashboard"
                  Click="Button_OnClick"
                  Classes="nav-button nav-button--active"/>

          <Button Content="Reports"
                  Click="Button_OnClick"
                  Classes="nav-button"/>

          <Button Content="Settings"
                  Click="Button_OnClick"
                  Classes="nav-button"/>
        </StackPanel>
            
      </StackPanel>
    </Border>
</UserControl>