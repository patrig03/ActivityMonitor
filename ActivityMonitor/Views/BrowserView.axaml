<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             x:DataType="viewModels:BrowserViewModel"
             x:Class="ActivityMonitor.Views.BrowserView">

  <UserControl.Resources>
    <DataTemplate x:Key="DomainTemplate" DataType="viewModels:BrowserDomainSummary">
      <Border Classes="panel-card panel-card--muted"
              Margin="0,0,0,10"
              Padding="14">
        <StackPanel Spacing="6">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="{Binding Domain}" Foreground="{StaticResource BrushTextSecondary}" FontWeight="Bold"/>
            <TextBlock Grid.Column="1" Text="{Binding RecordCount}" Foreground="{StaticResource BrushAccentPrimary}"/>
          </Grid>
          <TextBlock Text="{Binding Share}" Foreground="{StaticResource BrushTextMuted}"/>
          <TextBlock Text="{Binding SampleUrl}" Foreground="{StaticResource BrushTextSubtle}" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="BrowserAppTemplate" DataType="viewModels:BrowserAppSummary">
      <Border Classes="panel-card panel-card--muted"
              Margin="0,0,0,10"
              Padding="14">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding ProcessName}" Foreground="{StaticResource BrushTextSecondary}" FontWeight="Bold"/>
            <TextBlock Text="{Binding CategoryName}" Foreground="{StaticResource BrushTextMuted}"/>
          </StackPanel>
          <TextBlock Grid.Column="1" Text="{Binding RecordCount}" Foreground="{StaticResource BrushTextSecondary}" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="20" Spacing="18">
      <Border Classes="page-hero">
        <Grid ColumnDefinitions="*,300" ColumnSpacing="18">
          <StackPanel Spacing="10">
            <TextBlock Text="Activitate browser" Classes="page-title"/>
            <TextBlock Text="Inspecteaza URL-urile capturate, concentrarea pe domenii si procesele de browser monitorizate care genereaza cele mai multe inregistrari."
                       Classes="page-subtitle"/>
            <Border Classes="chip chip--overlay"
                    HorizontalAlignment="Left"
                    Margin="0,10,0,0">
              <TextBlock Text="{Binding BrowserStatus}" Foreground="{StaticResource BrushTextOnSoft}"/>
            </Border>
          </StackPanel>

          <Button Grid.Column="1"
                  Command="{Binding RefreshCommand}"
                  Classes="action-button primary-button"
                  Content="Reincarca datele browserului"
                  VerticalAlignment="Center"/>
        </Grid>
      </Border>

      <WrapPanel Orientation="Horizontal">
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Inregistrari browser" Classes="metric-label"/>
            <TextBlock Text="{Binding TotalEvents}" Classes="metric-value"/>
            <TextBlock Text="Total intrari URL capturate" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Domenii unice" Classes="metric-label"/>
            <TextBlock Text="{Binding UniqueDomains}" Classes="metric-value"/>
            <TextBlock Text="Gazde distincte in setul capturat" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Aplicatii browser monitorizate" Classes="metric-label"/>
            <TextBlock Text="{Binding TrackedBrowsers}" Classes="metric-value"/>
            <TextBlock Text="Id-uri distincte de aplicatii care produc inregistrari browser" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card" Width="260" Margin="0,0,0,14">
          <StackPanel Spacing="6">
            <TextBlock Text="Domeniu principal" Classes="metric-label"/>
            <TextBlock Text="{Binding TopDomain}" Classes="metric-value" TextWrapping="Wrap"/>
            <TextBlock Text="Cea mai frecventa gazda din setul curent de date browser" Classes="metric-detail"/>
          </StackPanel>
        </Border>
      </WrapPanel>

      <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
        <Border Classes="panel-card">
          <StackPanel Spacing="12">
            <TextBlock Text="Domenii principale" Classes="section-title"/>
            <TextBlock Text="Ce gazde apar cel mai des in setul curent de capturi." Classes="section-subtitle"/>
            <ItemsControl ItemsSource="{Binding TopDomains}" ItemTemplate="{StaticResource DomainTemplate}"/>
          </StackPanel>
        </Border>

        <Border Grid.Column="1" Classes="panel-card">
          <StackPanel Spacing="12">
            <TextBlock Text="Procese browser" Classes="section-title"/>
            <TextBlock Text="Aplicatii monitorizate care genereaza inregistrari URL." Classes="section-subtitle"/>
            <ItemsControl ItemsSource="{Binding BrowserApps}" ItemTemplate="{StaticResource BrowserAppTemplate}"/>
          </StackPanel>
        </Border>
      </Grid>

      <Border Classes="panel-card">
        <StackPanel Spacing="14">
          <TextBlock Text="URL-uri capturate recent" Classes="section-title"/>
          <TextBlock Text="Ordonate dupa cel mai nou id de activitate."
                     Classes="section-subtitle"/>
          <DataGrid ItemsSource="{Binding RecentActivity}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    SelectionMode="Single"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="True"
                    MinHeight="320">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Id" Binding="{Binding ActivityId}" Width="Auto"/>
              <DataGridTextColumn Header="Domeniu" Binding="{Binding Domain}" Width="1.5*"/>
              <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*"/>
              <DataGridTextColumn Header="Proces" Binding="{Binding BrowserProcess}" Width="1.5*"/>
              <DataGridTextColumn Header="Categorie" Binding="{Binding CategoryName}" Width="1.5*"/>
              <DataGridTextColumn Header="Utilizator" Binding="{Binding UserId}" Width="Auto"/>
            </DataGrid.Columns>
          </DataGrid>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
