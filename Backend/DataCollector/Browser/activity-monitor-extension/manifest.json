{
  "manifest_version": 2,
  "name": "Activity Monitor - Firefox",
  "version": "1.0",
  "permissions": [
    "tabs",
    "<all_urls>",
    "http://127.0.0.1:8090/"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "activitymonitor@example.com"
    }
  },
  "browser_action": {
    "default_title": "Activity Monitor"
  }
}