<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             x:DataType="viewModels:DashboardViewModel"
             x:Class="ActivityMonitor.Views.QuickStatsBar">

  <Border CornerRadius="24"
          Padding="20"
          Background="{StaticResource BrushSurfacePrimary}"
          BorderBrush="{StaticResource BrushBorderPrimary}"
          BorderThickness="1">
    <WrapPanel Orientation="Horizontal"
               HorizontalAlignment="Stretch">

      <Border Classes="stat-card">
        <StackPanel Spacing="6">
          <TextBlock Text="Timp monitorizat" Classes="metric-label"/>
          <TextBlock Text="{Binding TotalUsage}" Classes="metric-value"/>
          <TextBlock Text="Timp activ in toate categoriile capturate." Classes="metric-detail"/>
        </StackPanel>
      </Border>

      <Border Classes="stat-card">
        <StackPanel Spacing="6">
          <TextBlock Text="Sesiuni" Classes="metric-label"/>
          <TextBlock Text="{Binding TotalSessions}" Classes="metric-value"/>
          <TextBlock Text="Sesiuni distincte de aplicatii capturate pentru fereastra curenta de raportare." Classes="metric-detail"/>
        </StackPanel>
      </Border>

      <Border Classes="stat-card">
        <StackPanel Spacing="6">
          <TextBlock Text="Sesiune medie" Classes="metric-label"/>
          <TextBlock Text="{Binding AverageSession}" Classes="metric-value"/>
          <TextBlock Text="Util pentru a observa perioade lungi fara schimbare de context." Classes="metric-detail"/>
        </StackPanel>
      </Border>

      <Border Classes="stat-card">
        <StackPanel Spacing="6">
          <TextBlock Text="Scor de concentrare" Classes="metric-label"/>
          <TextBlock Text="{Binding FocusScore}"
                     Classes="metric-value"
                     Foreground="{StaticResource BrushAccentSuccess}"/>
          <TextBlock Text="Ponderea timpului petrecut in categorii orientate spre munca." Classes="metric-detail"/>
        </StackPanel>
      </Border>

      <Border Classes="stat-card">
        <StackPanel Spacing="6">
          <TextBlock Text="Aplicatie principala" Classes="metric-label"/>
          <TextBlock Text="{Binding TopApplication}"
                     Classes="metric-value"
                     Foreground="{StaticResource BrushAccentPrimary}"
                     TextWrapping="Wrap"/>
          <TextBlock Text="Procesul care consuma cel mai mult timp de activitate monitorizat." Classes="metric-detail"/>
        </StackPanel>
      </Border>

      <Border Classes="stat-card"
              Margin="0,0,0,14">
        <StackPanel Spacing="6">
          <TextBlock Text="Puls interventii" Classes="metric-label"/>
          <TextBlock Text="{Binding InterventionPulse}"
                     Classes="metric-value"
                     Foreground="{StaticResource BrushAccentWarning}"
                     TextWrapping="Wrap"/>
          <TextBlock Text="Activitate recenta a pragurilor, utila pentru ajustarea limitelor." Classes="metric-detail"/>
        </StackPanel>
      </Border>

    </WrapPanel>
  </Border>
</UserControl>
