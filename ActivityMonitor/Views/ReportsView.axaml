<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             x:Class="ActivityMonitor.Views.ReportsView"
             x:DataType="viewModels:ReportsViewModel">

  <!-- <UserControl.Background> -->
  <!--   <LinearGradientBrush StartPoint="0,0" EndPoint="1,1"> -->
  <!--     <GradientStop Color="#0C1424" Offset="0"/> -->
  <!--     <GradientStop Color="#15233E" Offset="0.55"/> -->
  <!--     <GradientStop Color="#122033" Offset="1"/> -->
  <!--   </LinearGradientBrush> -->
  <!-- </UserControl.Background> -->

  <UserControl.Resources>
    <DataTemplate x:Key="TopProcessTemplate" DataType="viewModels:ReportProcessSummary">
      <Border Margin="0,0,10,10"
              Padding="12"
              CornerRadius="16"
              Background="#15243D"
              BorderBrush="#2A4367"
              BorderThickness="1">
        <StackPanel Spacing="4">
          <TextBlock Text="{Binding ProcessName}" Foreground="#F4F7FF" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding Duration}" Foreground="#8BFFB1" FontWeight="Bold"/>
          <TextBlock Text="{Binding WindowCount}" Foreground="#8EA0C3"/>
        </StackPanel>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="CategoryCardTemplate" DataType="viewModels:ReportCategoryCard">
      <Border Margin="0,0,0,16"
              Padding="20"
              CornerRadius="24"
              Background="#10192A"
              BorderBrush="#24324A"
              BorderThickness="1">
        <StackPanel Spacing="14">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="6">
              <TextBlock Text="{Binding CategoryName}" FontSize="20" FontWeight="Bold" Foreground="#F7FAFF"/>
              <TextBlock Text="{Binding Description}" Foreground="#8EA0C3" TextWrapping="Wrap"/>
            </StackPanel>
            <Border Grid.Column="1"
                    Background="#17233A"
                    CornerRadius="999"
                    Padding="12,6"
                    VerticalAlignment="Top">
              <TextBlock Text="{Binding TotalDuration}" Foreground="#F7FAFF" FontWeight="Bold"/>
            </Border>
          </Grid>

          <WrapPanel Orientation="Horizontal">
            <Border Margin="0,0,10,10" Background="#15243D" CornerRadius="999" Padding="12,6">
              <TextBlock Text="{Binding ApplicationCount}" Foreground="#D6E4FF"/>
            </Border>
            <Border Margin="0,0,10,10" Background="#15243D" CornerRadius="999" Padding="12,6">
              <TextBlock Text="{Binding WindowCount}" Foreground="#D6E4FF"/>
            </Border>
            <Border Margin="0,0,10,10" Background="#15243D" CornerRadius="999" Padding="12,6">
              <TextBlock Text="{Binding ThresholdCount}" Foreground="#D6E4FF"/>
            </Border>
            <Border Margin="0,0,10,10" Background="#15243D" CornerRadius="999" Padding="12,6">
              <TextBlock Text="{Binding InterventionCount}" Foreground="#D6E4FF"/>
            </Border>
            <Border Margin="0,0,0,10" Background="#15243D" CornerRadius="999" Padding="12,6">
              <TextBlock Text="{Binding BrowserActivityCount}" Foreground="#D6E4FF"/>
            </Border>
          </WrapPanel>

          <Border Padding="14"
                  CornerRadius="18"
                  Background="#132238"
                  BorderBrush="#28415F"
                  BorderThickness="1">
            <StackPanel Spacing="4">
              <TextBlock Text="Top workload" Foreground="#8EA0C3"/>
              <TextBlock Text="{Binding Highlight}" Foreground="#7DD3FC" FontSize="18" FontWeight="Bold"/>
            </StackPanel>
          </Border>

          <StackPanel Spacing="10">
            <TextBlock Text="Top processes" FontSize="16" FontWeight="SemiBold" Foreground="#F7FAFF"/>
            <ItemsControl ItemsSource="{Binding TopProcesses}" ItemTemplate="{StaticResource TopProcessTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </StackPanel>
        </StackPanel>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="18" Spacing="18">
      <Border CornerRadius="28"
              Padding="24"
              Background="#10192A"
              BorderBrush="#24324A"
              BorderThickness="1">
        <Grid ColumnDefinitions="*,340" ColumnSpacing="18">
          <StackPanel Spacing="10">
            <TextBlock Text="Reports" FontSize="30" FontWeight="Bold" Foreground="#F7FAFF"/>
            <TextBlock Text="Review category-level workload summaries and generate exportable snapshots from the MySQL activity database."
                       Foreground="#8EA0C3"
                       TextWrapping="Wrap"/>
            <WrapPanel Orientation="Horizontal">
              <Border Margin="0,10,10,0" Background="#17233A" CornerRadius="999" Padding="12,6">
                <TextBlock Text="{Binding LastGenerated}" Foreground="#D6E4FF"/>
              </Border>
              <Border Margin="0,10,10,0" Background="#17233A" CornerRadius="999" Padding="12,6">
                <TextBlock Text="{Binding ExportDirectory}" Foreground="#D6E4FF"/>
              </Border>
            </WrapPanel>
          </StackPanel>

          <Border Grid.Column="1"
                  CornerRadius="22"
                  Padding="18"
                  Background="#17233A"
                  BorderBrush="#30415D"
                  BorderThickness="1">
            <StackPanel Spacing="12">
              <TextBlock Text="Status" Foreground="#8EA0C3"/>
              <TextBlock Text="{Binding ReportStatus}" FontSize="18" FontWeight="Bold" Foreground="#F7FAFF" TextWrapping="Wrap"/>
              <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Command="{Binding RefreshCommand}"
                        Background="#D9E5F5"
                        Foreground="#112039"
                        CornerRadius="14"
                        BorderThickness="0"
                        Padding="16,12">
                  <TextBlock Text="Refresh" HorizontalAlignment="Center" FontWeight="Bold"/>
                </Button>
                <Button Grid.Column="1"
                        Command="{Binding ExportCsvCommand}"
                        Background="#8BD3A7"
                        Foreground="#062A16"
                        CornerRadius="14"
                        BorderThickness="0"
                        Padding="16,12">
                  <TextBlock Text="Export CSV" HorizontalAlignment="Center" FontWeight="Bold"/>
                </Button>
              </Grid>
              <Button Command="{Binding ExportPdfCommand}"
                      Background="#F4CA7A"
                      Foreground="#452B00"
                      CornerRadius="14"
                      BorderThickness="0"
                      Padding="16,12">
                <TextBlock Text="Export PDF" HorizontalAlignment="Center" FontWeight="Bold"/>
              </Button>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <WrapPanel Orientation="Horizontal">
        <Border Width="220" Margin="0,0,14,14" Padding="18" CornerRadius="20" Background="#10192A" BorderBrush="#24324A" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="Categories" Foreground="#8EA0C3"/>
            <TextBlock Text="{Binding CategoryCount}" Foreground="#F7FAFF" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Generated report cards" Foreground="#7386A8"/>
          </StackPanel>
        </Border>
        <Border Width="220" Margin="0,0,14,14" Padding="18" CornerRadius="20" Background="#10192A" BorderBrush="#24324A" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="Tracked time" Foreground="#8EA0C3"/>
            <TextBlock Text="{Binding TotalTrackedTime}" Foreground="#F7FAFF" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Across all reportable categories" Foreground="#7386A8"/>
          </StackPanel>
        </Border>
        <Border Width="220" Margin="0,0,14,14" Padding="18" CornerRadius="20" Background="#10192A" BorderBrush="#24324A" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="Processes" Foreground="#8EA0C3"/>
            <TextBlock Text="{Binding ApplicationCount}" Foreground="#F7FAFF" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Unique tracked processes" Foreground="#7386A8"/>
          </StackPanel>
        </Border>
        <Border Width="220" Margin="0,0,14,14" Padding="18" CornerRadius="20" Background="#10192A" BorderBrush="#24324A" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="Interventions" Foreground="#8EA0C3"/>
            <TextBlock Text="{Binding InterventionCount}" Foreground="#F7FAFF" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Threshold triggers in report scope" Foreground="#7386A8"/>
          </StackPanel>
        </Border>
        <Border Width="220" Margin="0,0,0,14" Padding="18" CornerRadius="20" Background="#10192A" BorderBrush="#24324A" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="Browser records" Foreground="#8EA0C3"/>
            <TextBlock Text="{Binding BrowserEventCount}" Foreground="#F7FAFF" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Captured URL entries" Foreground="#7386A8"/>
          </StackPanel>
        </Border>
      </WrapPanel>

      <ItemsControl ItemsSource="{Binding Categories}" ItemTemplate="{StaticResource CategoryCardTemplate}"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
