<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             xmlns:views="clr-namespace:ActivityMonitor.Views"
             x:Class="ActivityMonitor.Views.DashboardView"
             xmlns:dto="clr-namespace:Database.DTO;assembly=Database"
             x:DataType="viewModels:DatabaseViewModel"
             x:CompileBindings="True">

  <!-- Set the DataContext here in XAML when using compiled bindings -->
  <UserControl.DataContext>
    <viewModels:DatabaseViewModel/>
  </UserControl.DataContext>
  
  <Grid ColumnDefinitions="*" RowDefinitions="*" Background="#111111">
    <!-- Database Table on the left -->
    <views:DatabaseTable Grid.Column="0"/>
  </Grid>


</UserControl>