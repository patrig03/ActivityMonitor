<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             x:Class="ActivityMonitor.Views.DevicesView"
             x:DataType="viewModels:DevicesViewModel">

  <UserControl.Resources>
    <DataTemplate x:Key="DeviceCardTemplate" DataType="viewModels:AccountDeviceRow">
      <Border Classes="panel-card panel-card--muted"
              Margin="0,0,0,14"
              Padding="18">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="6">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding Name}"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrushTextSecondary}"/>
                <Border IsVisible="{Binding IsCurrentDevice}"
                        Classes="chip chip--success"
                        Padding="10,4">
                  <TextBlock Text="Dispozitivul curent"
                             Foreground="{StaticResource BrushTextSecondary}"
                             FontSize="11"
                             FontWeight="Bold"/>
                </Border>
              </StackPanel>
              <TextBlock Text="{Binding DeviceType}" Foreground="{StaticResource BrushTextMuted}" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding ActivitySummary}" Foreground="{StaticResource BrushTextPrimary}" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="8" HorizontalAlignment="Right">
              <Border Classes="chip chip--overlay" Padding="10,4">
                <TextBlock Text="{Binding StatusChip}" Foreground="{StaticResource BrushTextOnSoft}" FontSize="11" FontWeight="Bold"/>
              </Border>
              <Border Classes="chip" Padding="10,4">
                <TextBlock Text="{Binding TrustChip}" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" FontWeight="Bold"/>
              </Border>
            </StackPanel>
          </Grid>

          <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
            <Border Classes="panel-card panel-card--overlay" Padding="14">
              <StackPanel Spacing="4">
                <TextBlock Text="Platforma" Classes="metric-label"/>
                <TextBlock Text="{Binding Platform}" Foreground="{StaticResource BrushTextSecondary}" FontWeight="SemiBold"/>
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="panel-card panel-card--overlay" Padding="14">
              <StackPanel Spacing="4">
                <TextBlock Text="Ultima activitate" Classes="metric-label"/>
                <TextBlock Text="{Binding LastSeenLabel}" Foreground="{StaticResource BrushTextSecondary}" FontWeight="SemiBold"/>
              </StackPanel>
            </Border>
          </Grid>

          <TextBlock Text="{Binding VersionSummary}" Foreground="{StaticResource BrushTextMuted}"/>
        </StackPanel>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="20" Spacing="18">

      <Border Classes="page-hero">
        <Grid ColumnDefinitions="*,340" ColumnSpacing="18">
          <StackPanel Spacing="10">
            <TextBlock Text="Dispozitive" Classes="page-title"/>
            <TextBlock Text="{Binding PageSubtitle}" Classes="page-subtitle"/>

            <WrapPanel Orientation="Horizontal">
              <Border Classes="chip chip--overlay" Margin="0,10,10,0">
                <TextBlock Text="{Binding AccountLabel}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
              <Border Classes="chip chip--overlay" Margin="0,10,10,0">
                <TextBlock Text="{Binding CurrentDeviceLabel}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
              <Border Classes="chip chip--overlay" Margin="0,10,10,0">
                <TextBlock Text="{Binding LastRefreshLabel}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
              <Border Classes="chip chip--overlay" Margin="0,10,0,0">
                <TextBlock Text="{Binding LastServerSyncLabel}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
            </WrapPanel>
          </StackPanel>

          <Border Grid.Column="1"
                  Classes="panel-card panel-card--overlay"
                  Padding="18">
            <StackPanel Spacing="12">
              <TextBlock Text="Stare cont" Foreground="{StaticResource BrushTextMuted}"/>
              <TextBlock Text="{Binding DeviceStatus}"
                         FontSize="20"
                         FontWeight="Bold"
                         Foreground="{StaticResource BrushTextSecondary}"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding CurrentDeviceDetail}"
                         Foreground="{StaticResource BrushTextPrimary}"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding SyncServerLabel}"
                         Foreground="{StaticResource BrushTextMuted}"
                         TextWrapping="Wrap"/>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Command="{Binding SyncWithServerCommand}"
                        Classes="action-button primary-button"
                        Content="Sincronizează"/>
                <Button Grid.Column="1"
                        Command="{Binding RefreshCommand}"
                        Classes="action-button subtle-button"
                        Content="Reîncarcă"/>
              </Grid>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <WrapPanel Orientation="Horizontal">
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Total dispozitive" Classes="metric-label"/>
            <TextBlock Text="{Binding TotalDevices}" Classes="metric-value"/>
            <TextBlock Text="Raportate de contul server" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Active" Classes="metric-label"/>
            <TextBlock Text="{Binding ActiveDevices}" Classes="metric-value"/>
            <TextBlock Text="Cu status activ" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Revocate" Classes="metric-label"/>
            <TextBlock Text="{Binding RevokedDevices}" Classes="metric-value"/>
            <TextBlock Text="Acces retras de server" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card" Margin="0,0,0,14">
          <StackPanel Spacing="6">
            <TextBlock Text="Status necunoscut" Classes="metric-label"/>
            <TextBlock Text="{Binding UnknownDevices}" Classes="metric-value"/>
            <TextBlock Text="Fara stare explicita" Classes="metric-detail"/>
          </StackPanel>
        </Border>
      </WrapPanel>

      <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="18">
        <Border Classes="panel-card panel-card--success">
          <StackPanel Spacing="14">
            <TextBlock Text="Dispozitive conectate pe server" Classes="section-title"/>
            <TextBlock Text="Lista de mai jos vine din contul autentificat pe serverul de sincronizare, nu din inventarul local al aplicației."
                       Classes="section-subtitle"/>

            <ListBox ItemsSource="{Binding Devices}"
                     SelectedItem="{Binding SelectedDevice}"
                     ItemTemplate="{StaticResource DeviceCardTemplate}"
                     Background="Transparent"
                     BorderThickness="0"
                     MaxHeight="720"
                     SelectionMode="Single"/>
          </StackPanel>
        </Border>

        <StackPanel Grid.Column="1" Spacing="18">
          <Border Classes="panel-card">
            <StackPanel Spacing="14">
              <TextBlock Text="Detalii dispozitiv"
                         Classes="section-title"/>

              <StackPanel IsVisible="{Binding HasSelectedDevice}" Spacing="14">
                <TextBlock Text="{Binding SelectedDeviceState}"
                           Foreground="{StaticResource BrushTextSecondary}"
                           FontWeight="SemiBold"
                           FontSize="16"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding SelectedDeviceTimeline}"
                           Foreground="{StaticResource BrushTextMuted}"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding SelectedDeviceTrust}"
                           Foreground="{StaticResource BrushTextMuted}"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding SelectedDeviceServerStatus}"
                           Foreground="{StaticResource BrushTextPrimary}"
                           TextWrapping="Wrap"/>

                <Border Classes="panel-card panel-card--overlay"
                        Padding="14">
                  <StackPanel Spacing="6">
                    <TextBlock Text="ID server" Classes="field-label"/>
                    <TextBlock Text="{Binding SelectedDeviceIdentifier}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                  <Border Classes="panel-card panel-card--overlay"
                          Padding="14">
                    <StackPanel Spacing="6">
                      <TextBlock Text="Tip dispozitiv" Classes="field-label"/>
                      <TextBlock Text="{Binding SelectedDeviceType}"
                                 Foreground="{StaticResource BrushTextSecondary}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="1"
                          Classes="panel-card panel-card--overlay"
                          Padding="14">
                    <StackPanel Spacing="6">
                      <TextBlock Text="Platforma" Classes="field-label"/>
                      <TextBlock Text="{Binding SelectedDevicePlatform}"
                                 Foreground="{StaticResource BrushTextSecondary}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                </Grid>

                <Border Classes="panel-card panel-card--overlay"
                        Padding="14">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Versiune client" Classes="field-label"/>
                    <TextBlock Text="{Binding SelectedDeviceVersion}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>

                <Button Command="{Binding ClearSelectionCommand}"
                        Classes="action-button subtle-button"
                        Content="Curata selectia"/>
              </StackPanel>

              <StackPanel IsVisible="{Binding NoSelectedDevice}" Spacing="10">
                <TextBlock Text="Niciun dispozitiv selectat"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextSecondary}"/>
                <TextBlock Text="Selecteaza un dispozitiv din lista pentru a vedea statusul, identificatorul si activitatea raportata de server."
                           Foreground="{StaticResource BrushTextMuted}"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="panel-card panel-card--warning">
            <StackPanel Spacing="12">
              <TextBlock Text="Cum apare un dispozitiv aici" Classes="section-title"/>
              <TextBlock Text="Un dispozitiv apare in aceasta pagina dupa ce sesiunea locala este autentificata si rulezi o sincronizare. Pagina afiseaza exact ceea ce raporteaza endpoint-ul /api/devices pentru contul curent."
                         Classes="section-subtitle"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
