<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             xmlns:views="using:ActivityMonitor.Views"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="900"
             x:Class="ActivityMonitor.Views.InterventionsView"
             x:DataType="viewModels:InterventionsViewModel">

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="20" Spacing="18">
      <Border Classes="page-hero">
        <Grid ColumnDefinitions="*,320" ColumnSpacing="18">
          <StackPanel Spacing="10">
            <TextBlock Text="Intervenții" Classes="page-title"/>
            <TextBlock Text="Configurează limitele, revizuiește istoricul declanșărilor și păstrează comportamentul monitorului aliniat cu modul tău real de lucru."
                       Classes="page-subtitle"/>
            <WrapPanel Orientation="Horizontal">
              <Border Classes="chip chip--overlay" Margin="0,10,10,0">
                <TextBlock Text="{Binding ThresholdStatus}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
              <Border Classes="chip chip--overlay" Margin="0,10,0,0">
                <TextBlock Text="{Binding MostTriggeredTarget}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
            </WrapPanel>
          </StackPanel>

          <Border Grid.Column="1"
                  Classes="panel-card panel-card--overlay"
                  Padding="18">
            <StackPanel Spacing="12">
              <TextBlock Text="Mentenanta" Foreground="{StaticResource BrushTextMuted}"/>
              <TextBlock Text="Reîncarcă limitele și istoricul intervențiilor din baza de date MySQL." Foreground="{StaticResource BrushTextSecondary}" FontWeight="SemiBold" TextWrapping="Wrap"/>
              <Button Command="{Binding RefreshCommand}"
                      Classes="action-button success-button"
                      Content="Reîncarcă datele"/>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <WrapPanel Orientation="Horizontal">
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Praguri active" Classes="metric-label"/>
            <TextBlock Text="{Binding ActiveThresholdCount}" Classes="metric-value"/>
            <TextBlock Text="Reguli care aplica in prezent interventii" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Praguri inactive" Classes="metric-label"/>
            <TextBlock Text="{Binding InactiveThresholdCount}" Classes="metric-value"/>
            <TextBlock Text="Reguli salvate care asteapta sa fie reactivate" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Acoperire categorii" Classes="metric-label"/>
            <TextBlock Text="{Binding CategoryCoverage}" Classes="metric-value"/>
            <TextBlock Text="Categorii distincte protejate prin praguri" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Alerte in 7 zile" Classes="metric-label"/>
            <TextBlock Text="{Binding RecentAlertCount}" Classes="metric-value"/>
            <TextBlock Text="Presiune recenta a interventiilor" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card" Margin="0,0,0,14">
          <StackPanel Spacing="6">
            <TextBlock Text="Alerte amanate" Classes="metric-label"/>
            <TextBlock Text="{Binding SnoozedAlertCount}" Classes="metric-value"/>
            <TextBlock Text="Intervenții amânate de utilizator" Classes="metric-detail"/>
          </StackPanel>
        </Border>
      </WrapPanel>

      <StackPanel Spacing="18">
        <views:AddThresholdView/>

        <Border Classes="panel-card">
          <StackPanel Spacing="14">
            <TextBlock Text="Inventar praguri" Classes="section-title"/>
            <TextBlock Text="Editeaza sau elimina limitele direct din tabelul curent al pragurilor." Classes="section-subtitle"/>
            <views:CurrentThresholdsView/>
          </StackPanel>
        </Border>

        <Border Classes="panel-card">
          <StackPanel Spacing="14">
            <TextBlock Text="Istoric interventii" Classes="section-title"/>
            <TextBlock Text="Toate interventiile inregistrate, cele mai noi primele." Classes="section-subtitle"/>
            <DataGrid ItemsSource="{Binding InterventionHistory}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      FontSize="13"
                      MinHeight="280">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="Auto"/>
                <DataGridTextColumn Header="Declansat la" Binding="{Binding TriggeredAt}" Width="2*"/>
                <DataGridTextColumn Header="Tinta" Binding="{Binding TargetName}" Width="2*"/>
                <DataGridTextColumn Header="Tip tinta" Binding="{Binding TargetType}" Width="Auto"/>
                <DataGridTextColumn Header="Categorie" Binding="{Binding CategoryName}" Width="2*"/>
                <DataGridTextColumn Header="Interventie" Binding="{Binding InterventionType}" Width="Auto"/>
                <DataGridTextColumn Header="Limita" Binding="{Binding LimitSummary}" Width="Auto"/>
                <DataGridTextColumn Header="Amanat" Binding="{Binding Snoozed}" Width="Auto"/>
              </DataGrid.Columns>
            </DataGrid>
          </StackPanel>
        </Border>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
