<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             x:Class="ActivityMonitor.Views.ReportsView"
             x:DataType="viewModels:ReportsViewModel">

  <UserControl.Resources>
    <DataTemplate x:Key="TopProcessTemplate" DataType="viewModels:ReportProcessSummary">
      <Border Classes="panel-card panel-card--muted"
              Margin="0,0,10,10"
              Padding="12">
        <StackPanel Spacing="4">
          <TextBlock Text="{Binding ProcessName}" Foreground="{StaticResource BrushTextSecondary}" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding Duration}" Foreground="{StaticResource BrushAccentSuccess}" FontWeight="Bold"/>
          <TextBlock Text="{Binding WindowCount}" Foreground="{StaticResource BrushTextMuted}"/>
        </StackPanel>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="CategoryCardTemplate" DataType="viewModels:ReportCategoryCard">
      <Border Classes="panel-card"
              Margin="0,0,0,16">
        <StackPanel Spacing="14">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="6">
              <TextBlock Text="{Binding CategoryName}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource BrushTextSecondary}"/>
              <TextBlock Text="{Binding Description}" Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap"/>
            </StackPanel>
            <Border Grid.Column="1"
                    Classes="chip chip--overlay"
                    VerticalAlignment="Top">
              <TextBlock Text="{Binding TotalDuration}" Foreground="{StaticResource BrushTextSecondary}" FontWeight="Bold"/>
            </Border>
          </Grid>

          <WrapPanel Orientation="Horizontal">
            <Border Classes="chip chip--overlay" Margin="0,0,10,10">
              <TextBlock Text="{Binding ApplicationCount}" Foreground="{StaticResource BrushTextOnSoft}"/>
            </Border>
            <Border Classes="chip chip--overlay" Margin="0,0,10,10">
              <TextBlock Text="{Binding WindowCount}" Foreground="{StaticResource BrushTextOnSoft}"/>
            </Border>
            <Border Classes="chip chip--overlay" Margin="0,0,10,10">
              <TextBlock Text="{Binding ThresholdCount}" Foreground="{StaticResource BrushTextOnSoft}"/>
            </Border>
            <Border Classes="chip chip--overlay" Margin="0,0,10,10">
              <TextBlock Text="{Binding InterventionCount}" Foreground="{StaticResource BrushTextOnSoft}"/>
            </Border>
            <Border Classes="chip chip--overlay" Margin="0,0,0,10">
              <TextBlock Text="{Binding BrowserActivityCount}" Foreground="{StaticResource BrushTextOnSoft}"/>
            </Border>
          </WrapPanel>

          <Border Classes="panel-card panel-card--muted"
                  Padding="14">
            <StackPanel Spacing="4">
              <TextBlock Text="Activitate dominanta" Foreground="{StaticResource BrushTextMuted}"/>
              <TextBlock Text="{Binding Highlight}" Foreground="{StaticResource BrushAccentPrimary}" FontSize="18" FontWeight="Bold"/>
            </StackPanel>
          </Border>

          <StackPanel Spacing="10">
            <TextBlock Text="Procese principale" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource BrushTextSecondary}"/>
            <ItemsControl ItemsSource="{Binding TopProcesses}" ItemTemplate="{StaticResource TopProcessTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </StackPanel>
        </StackPanel>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="20" Spacing="18">
      <Border Classes="page-hero">
        <Grid ColumnDefinitions="*,340" ColumnSpacing="18">
          <StackPanel Spacing="10">
            <TextBlock Text="Rapoarte" Classes="page-title"/>
            <TextBlock Text="Revizuieste sumarurile de activitate pe categorii si genereaza instantanee exportabile din baza de date MySQL."
                       Classes="page-subtitle"/>
            <WrapPanel Orientation="Horizontal">
              <Border Classes="chip chip--overlay" Margin="0,10,10,0">
                <TextBlock Text="{Binding LastGenerated}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
              <Border Classes="chip chip--overlay" Margin="0,10,10,0">
                <TextBlock Text="{Binding ExportDirectory}" Foreground="{StaticResource BrushTextOnSoft}"/>
              </Border>
            </WrapPanel>
          </StackPanel>

          <Border Grid.Column="1"
                  Classes="panel-card panel-card--overlay"
                  Padding="18">
            <StackPanel Spacing="12">
              <TextBlock Text="Stare" Foreground="{StaticResource BrushTextMuted}"/>
              <TextBlock Text="{Binding ReportStatus}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushTextSecondary}" TextWrapping="Wrap"/>
              <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Command="{Binding RefreshCommand}"
                        Classes="action-button subtle-button"
                        Content="Reincarca"/>
                <Button Grid.Column="1"
                        Command="{Binding ExportCsvCommand}"
                        Classes="action-button success-button"
                        Content="Exporta CSV"/>
              </Grid>
              <Button Command="{Binding ExportPdfCommand}"
                      Classes="action-button warning-button"
                      Content="Exporta PDF"/>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <WrapPanel Orientation="Horizontal">
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Categorii" Classes="metric-label"/>
            <TextBlock Text="{Binding CategoryCount}" Classes="metric-value"/>
            <TextBlock Text="Carduri de raport generate" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Timp monitorizat" Classes="metric-label"/>
            <TextBlock Text="{Binding TotalTrackedTime}" Classes="metric-value"/>
            <TextBlock Text="Pe toate categoriile raportabile" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Procese" Classes="metric-label"/>
            <TextBlock Text="{Binding ApplicationCount}" Classes="metric-value"/>
            <TextBlock Text="Procese monitorizate unice" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card">
          <StackPanel Spacing="6">
            <TextBlock Text="Interventii" Classes="metric-label"/>
            <TextBlock Text="{Binding InterventionCount}" Classes="metric-value"/>
            <TextBlock Text="Declansari de prag din aria raportului" Classes="metric-detail"/>
          </StackPanel>
        </Border>
        <Border Classes="stat-card" Margin="0,0,0,14">
          <StackPanel Spacing="6">
            <TextBlock Text="Inregistrari browser" Classes="metric-label"/>
            <TextBlock Text="{Binding BrowserEventCount}" Classes="metric-value"/>
            <TextBlock Text="Intrari URL capturate" Classes="metric-detail"/>
          </StackPanel>
        </Border>
      </WrapPanel>

      <ItemsControl ItemsSource="{Binding Categories}" ItemTemplate="{StaticResource CategoryCardTemplate}"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
