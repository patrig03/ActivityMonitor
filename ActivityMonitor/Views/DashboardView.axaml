<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ActivityMonitor.Views"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:DataType="viewModels:DashboardViewModel"
             x:Class="ActivityMonitor.Views.DashboardView"
             Background="#101010"
             Foreground="White">

  <Grid Margin="12" RowDefinitions="Auto,Auto,*,*,*">

    <!-- ================= HEADER ================= -->
    <DockPanel Margin="0,0,0,12">
      <!-- User Profile -->
      <Button CornerRadius="8"
              Background="#212121"
              Padding="4"
              BorderThickness="0"
              DockPanel.Dock="Right">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Border CornerRadius="6"
                  Background="#212121"
                  Width="36"
                  Height="36"
                  VerticalAlignment="Center">
            <TextBlock Text="JD"
                       Foreground="White"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
          <StackPanel VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="John Doe"
                       Foreground="#EAF1FF"
                       FontWeight="Medium"
                       FontSize="13"/>
            <TextBlock Text="Admin"
                       Foreground="#7C879C"
                       FontSize="11"/>
          </StackPanel>
          <PathIcon Data="M7,10L12,15L17,10H7Z"
                    Width="16"
                    Height="16"
                    Foreground="#AAB3C6"
                    VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <!-- Notifications -->
      <Button Margin="8,0,0,0" CornerRadius="8" Background="#212121">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PathIcon Data="M12,22C13.1,22 14,21.1 14,20H10C10,21.1 10.9,22 12,22ZM18,16V11C18,7.9 16.4,5.4 13.5,4.7V4C13.5,3.2 12.8,2.5 12,2.5C11.2,2.5 10.5,3.2 10.5,4V4.7C7.6,5.4 6,7.9 6,11V16L4,18V19H20V18L18,16Z"
                    Width="18" Height="18" Foreground="White"/>
          <TextBlock Text="Notifications" Foreground="White" VerticalAlignment="Center"/>
          <Border Background="#444444"
                  CornerRadius="10"
                  Padding="6,2"
                  VerticalAlignment="Center">
            <TextBlock Text="3" Foreground="White" FontSize="10" FontWeight="Bold"/>
          </Border>
        </StackPanel>
      </Button>
    </DockPanel>

    <!-- ================= QUICK STATS ================= -->
    <views:QuickStatsBar Grid.Row="1" Margin="0,0,0,24"/>

    <!-- ================= GRAPHS ================= -->
    <StackPanel Grid.Row="2" Orientation="Vertical" Spacing="12" Margin="0,0,0,12">

      <Grid ColumnDefinitions="*,*"
            RowDefinitions="*,*"
            ColumnSpacing="12">

        <lvc:CartesianChart Grid.Column="0"
                            Series="{Binding WindowUsageSeries}"
                            MinHeight="350"/>
        <TextBlock Grid.Column="0"
                   Grid.Row="1" Margin="0,4,0,0"
                   FontSize="14" Foreground="White"
                   Text="Top 10 most-used windows by total active time." 
                   TextAlignment="Center"/>

        <lvc:PieChart Grid.Column="1"
                      Grid.Row="0" 
                      Series="{Binding ProcessShareSeries}"
                      MinHeight="350"/>
        <TextBlock  Grid.Column="1" 
                    Grid.Row="1" Margin="0,4,0,0"
                    FontSize="14" Foreground="White"
                    Text="CPU‑time distribution across running processes." 
                    TextAlignment="Center"/>
      </Grid>

      <lvc:CartesianChart Series="{Binding SessionTimelineSeries}"
                          MinHeight="350"/>
      <TextBlock Margin="0,4,0,0"
                 FontSize="14" Foreground="White"
                 Text="Duration of each user session in minutes over time."
                 TextAlignment="Center"/>
    </StackPanel>

  </Grid>
</UserControl>