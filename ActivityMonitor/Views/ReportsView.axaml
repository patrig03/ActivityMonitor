<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             x:Class="ActivityMonitor.Views.ReportsView"
             x:DataType="viewModels:ReportsViewModel">
  

  <ScrollViewer>
    <ItemsControl ItemsSource="{Binding Reports}">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <StackPanel Margin="20" Spacing="12">

            <TextBlock Text="{Binding CategoryName}"
                       FontSize="18" FontWeight="Bold"/>

            <TextBlock Text="{Binding ApplicationName}"
                       FontSize="16" FontWeight="SemiBold"/>

            <TextBlock Text="{Binding SessionDetails}"/>

          </StackPanel>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </ScrollViewer>
</UserControl>
