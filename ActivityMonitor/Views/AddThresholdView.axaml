<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             xmlns:converters="clr-namespace:ActivityMonitor.Converters"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="ActivityMonitor.Views.AddThresholdView"
             x:DataType="viewModels:InterventionsViewModel">

  <UserControl.Resources>
    <converters:EqualsConverter x:Key="EqualsConverter"/>
  </UserControl.Resources>

  <StackPanel Spacing="12">
    <Border Padding="18"
            CornerRadius="24"
            Background="#121926"
            BorderBrush="#273043"
            BorderThickness="1">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
        <StackPanel Spacing="4">
          <TextBlock Text="Reguli de prag" FontSize="20" FontWeight="Bold" Foreground="#F7FAFF"/>
          <TextBlock Text="Creeaza o limita pentru o categorie sau aplicatie, decide cat timp este permis si alege ce se intampla cand limita este depasita."
                     Foreground="#9AA8C1"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <Button Grid.Column="1"
                Content="Adauga prag"
                VerticalAlignment="Center"
                Command="{Binding AddCommand}"
                Background="#8BD3A7"
                Foreground="#062A16"
                BorderThickness="0"
                CornerRadius="14"
                Padding="16,12"/>
      </Grid>
    </Border>

    <Border IsVisible="{Binding IsScrollViewerVisible}"
            Padding="20"
            CornerRadius="24"
            Background="#121926"
            BorderBrush="#273043"
            BorderThickness="1">
      <StackPanel Spacing="16">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding ThresholdFormTitle}" FontSize="22" FontWeight="Bold" Foreground="#F7FAFF"/>
            <TextBlock Text="Ajusteaza tinta, tipul limitei si interventia inainte sa salvezi regula."
                       Foreground="#9AA8C1"
                       TextWrapping="Wrap"/>
          </StackPanel>

          <Button Grid.Column="1"
                  Content="Anuleaza"
                  VerticalAlignment="Top"
                  Command="{Binding CancelCommand}"
                  Background="#D9E5F5"
                  Foreground="#112039"
                  BorderThickness="0"
                  CornerRadius="14"
                  Padding="16,12"/>
        </Grid>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
          <Border Padding="16"
                  CornerRadius="20"
                  Background="#1A2334"
                  BorderBrush="#31415C"
                  BorderThickness="1">
            <StackPanel Spacing="12">
              <TextBlock Text="Tinta" FontSize="16" FontWeight="SemiBold" Foreground="#F7FAFF"/>

              <StackPanel Spacing="6">
                <TextBlock Text="Tip tinta" Foreground="#D8E4F8"/>
                <ComboBox ItemsSource="{Binding TargetTypes}"
                          SelectedItem="{Binding EditData.Threshold.TargetType}"/>
              </StackPanel>

              <StackPanel Spacing="6"
                          IsVisible="{Binding EditData.Threshold.TargetType, Converter={StaticResource EqualsConverter}, ConverterParameter=Category}">
                <TextBlock Text="Categorie" Foreground="#D8E4F8"/>
                <ComboBox ItemsSource="{Binding Categories}"
                          SelectedValue="{Binding EditData.Threshold.CategoryId}"
                          SelectedValueBinding="{Binding Id}"
                          DisplayMemberBinding="{Binding Name}"/>
              </StackPanel>

              <StackPanel Spacing="6"
                          IsVisible="{Binding EditData.Threshold.TargetType, Converter={StaticResource EqualsConverter}, ConverterParameter=App}">
                <TextBlock Text="Aplicatie" Foreground="#D8E4F8"/>
                <ComboBox ItemsSource="{Binding Apps}"
                          SelectedValue="{Binding EditData.Threshold.AppId}"
                          SelectedValueBinding="{Binding Id}"
                          DisplayMemberBinding="{Binding ProcessName}"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Grid.Column="1"
                  Padding="16"
                  CornerRadius="20"
                  Background="#1A2334"
                  BorderBrush="#31415C"
                  BorderThickness="1">
            <StackPanel Spacing="12">
              <TextBlock Text="Regula" FontSize="16" FontWeight="SemiBold" Foreground="#F7FAFF"/>

              <CheckBox Content="Pragul este activ"
                        IsChecked="{Binding EditData.Threshold.Active}"/>

              <StackPanel Spacing="6">
                <TextBlock Text="Tip limita" Foreground="#D8E4F8"/>
                <ComboBox ItemsSource="{Binding LimitTypes}"
                          SelectedItem="{Binding EditData.Threshold.LimitType}"/>
              </StackPanel>

              <StackPanel Spacing="6"
                          IsVisible="{Binding EditData.Threshold.LimitType, Converter={StaticResource EqualsConverter}, ConverterParameter=Daily}">
                <TextBlock Text="Limita zilnica (hh:mm:ss)" Foreground="#D8E4F8"/>
                <TextBox Text="{Binding EditData.Threshold.DailyLimit}"/>
              </StackPanel>

              <StackPanel Spacing="6"
                          IsVisible="{Binding EditData.Threshold.LimitType, Converter={StaticResource EqualsConverter}, ConverterParameter=Session}">
                <TextBlock Text="Limita sesiune (hh:mm:ss)" Foreground="#D8E4F8"/>
                <TextBox Text="{Binding EditData.Threshold.SessionLimit}"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>

        <Border Padding="16"
                CornerRadius="20"
                Background="#1A2334"
                BorderBrush="#31415C"
                BorderThickness="1">
          <StackPanel Spacing="12">
            <TextBlock Text="Interventie" FontSize="16" FontWeight="SemiBold" Foreground="#F7FAFF"/>

            <StackPanel Spacing="6">
              <TextBlock Text="Tip interventie" Foreground="#D8E4F8"/>
              <ComboBox ItemsSource="{Binding InterventionTypes}"
                        SelectedItem="{Binding EditData.Threshold.InterventionType}"/>
            </StackPanel>

            <TextBlock Text="Blocarea tastarii foloseste in prezent expresia implicita de deblocare."
                       Foreground="#9AA8C1"
                       TextWrapping="Wrap"
                       IsVisible="{Binding EditData.Threshold.InterventionType, Converter={StaticResource EqualsConverter}, ConverterParameter=TypingLock}"/>

            <TextBlock Text="Blocarea temporizata foloseste in prezent durata implicita de blocare."
                       Foreground="#9AA8C1"
                       TextWrapping="Wrap"
                       IsVisible="{Binding EditData.Threshold.InterventionType, Converter={StaticResource EqualsConverter}, ConverterParameter=TimedLock}"/>
          </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <Button Content="Anuleaza"
                  Command="{Binding CancelCommand}"
                  Background="#D9E5F5"
                  Foreground="#112039"
                  BorderThickness="0"
                  CornerRadius="14"
                  Padding="16,12"/>
          <Button Content="Salveaza pragul"
                  Command="{Binding SaveCommand}"
                  Background="#8BD3A7"
                  Foreground="#062A16"
                  BorderThickness="0"
                  CornerRadius="14"
                  Padding="16,12"/>
        </StackPanel>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
