<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             xmlns:views="using:ActivityMonitor.Views"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="900"
             x:Class="ActivityMonitor.Views.InterventionsView"
             x:DataType="viewModels:InterventionsViewModel"
             Foreground="White">

  <!-- <UserControl.Background> -->
  <!--   <LinearGradientBrush StartPoint="0,0" EndPoint="1,1"> -->
  <!--     <GradientStop Color="#0C101A" Offset="0"/> -->
  <!--     <GradientStop Color="#171C2A" Offset="0.55"/> -->
  <!--     <GradientStop Color="#121722" Offset="1"/> -->
  <!--   </LinearGradientBrush> -->
  <!-- </UserControl.Background> -->

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="18" Spacing="18">
      <Border CornerRadius="28"
              Padding="24"
              Background="#121926"
              BorderBrush="#273043"
              BorderThickness="1">
        <Grid ColumnDefinitions="*,320" ColumnSpacing="18">
          <StackPanel Spacing="10">
            <TextBlock Text="Interventions" FontSize="30" FontWeight="Bold" Foreground="#F7FAFF"/>
            <TextBlock Text="Configure guardrails, review trigger history, and keep the monitor's behavior aligned with how you actually work."
                       Foreground="#9AA8C1"
                       TextWrapping="Wrap"/>
            <WrapPanel Orientation="Horizontal">
              <Border Margin="0,10,10,0" Background="#1A2334" CornerRadius="999" Padding="12,6">
                <TextBlock Text="{Binding ThresholdStatus}" Foreground="#D8E4F8"/>
              </Border>
              <Border Margin="0,10,0,0" Background="#1A2334" CornerRadius="999" Padding="12,6">
                <TextBlock Text="{Binding MostTriggeredTarget}" Foreground="#D8E4F8"/>
              </Border>
            </WrapPanel>
          </StackPanel>

          <Border Grid.Column="1"
                  CornerRadius="22"
                  Padding="18"
                  Background="#1A2334"
                  BorderBrush="#31415C"
                  BorderThickness="1">
            <StackPanel Spacing="12">
              <TextBlock Text="Maintenance" Foreground="#9AA8C1"/>
              <TextBlock Text="Refresh guardrails and intervention history from the MySQL database." Foreground="#F7FAFF" FontWeight="SemiBold" TextWrapping="Wrap"/>
              <Button Command="{Binding RefreshCommand}"
                      Background="#8BD3A7"
                      Foreground="#062A16"
                      BorderThickness="0"
                      CornerRadius="14"
                      Padding="16,12">
                <TextBlock Text="Refresh data" HorizontalAlignment="Center" FontWeight="Bold"/>
              </Button>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <WrapPanel Orientation="Horizontal">
        <Border Width="220" Margin="0,0,14,14" Padding="18" CornerRadius="20" Background="#121926" BorderBrush="#273043" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="Active thresholds" Foreground="#9AA8C1"/>
            <TextBlock Text="{Binding ActiveThresholdCount}" Foreground="#F7FAFF" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Rules currently enforcing interventions" Foreground="#73839F" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
        <Border Width="220" Margin="0,0,14,14" Padding="18" CornerRadius="20" Background="#121926" BorderBrush="#273043" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="Inactive thresholds" Foreground="#9AA8C1"/>
            <TextBlock Text="{Binding InactiveThresholdCount}" Foreground="#F7FAFF" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Saved rules waiting to be re-enabled" Foreground="#73839F" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
        <Border Width="220" Margin="0,0,14,14" Padding="18" CornerRadius="20" Background="#121926" BorderBrush="#273043" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="Category coverage" Foreground="#9AA8C1"/>
            <TextBlock Text="{Binding CategoryCoverage}" Foreground="#F7FAFF" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Distinct categories with threshold protection" Foreground="#73839F" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
        <Border Width="220" Margin="0,0,14,14" Padding="18" CornerRadius="20" Background="#121926" BorderBrush="#273043" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="Alerts in 7 days" Foreground="#9AA8C1"/>
            <TextBlock Text="{Binding RecentAlertCount}" Foreground="#F7FAFF" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Recent intervention pressure" Foreground="#73839F" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
        <Border Width="220" Margin="0,0,0,14" Padding="18" CornerRadius="20" Background="#121926" BorderBrush="#273043" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="Snoozed alerts" Foreground="#9AA8C1"/>
            <TextBlock Text="{Binding SnoozedAlertCount}" Foreground="#F7FAFF" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Interventions deferred by the user" Foreground="#73839F" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
      </WrapPanel>

      <Grid ColumnDefinitions="1.2*,0.8*" ColumnSpacing="18">
        <StackPanel Spacing="18">
          <views:AddThresholdView/>

          <Border Padding="18"
                  CornerRadius="24"
                  Background="#121926"
                  BorderBrush="#273043"
                  BorderThickness="1">
            <StackPanel Spacing="14">
              <TextBlock Text="Threshold inventory" FontSize="20" FontWeight="Bold" Foreground="#F7FAFF"/>
              <TextBlock Text="Edit or remove limits directly from the current threshold table." Foreground="#9AA8C1" TextWrapping="Wrap"/>
              <views:CurrentThresholdsView/>
            </StackPanel>
          </Border>

          <Border Padding="18"
                  CornerRadius="24"
                  Background="#121926"
                  BorderBrush="#273043"
                  BorderThickness="1">
            <StackPanel Spacing="14">
              <TextBlock Text="Intervention history" FontSize="20" FontWeight="Bold" Foreground="#F7FAFF"/>
              <TextBlock Text="Every recorded intervention, newest first." Foreground="#9AA8C1"/>
              <DataGrid ItemsSource="{Binding InterventionHistory}"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        SelectionMode="Single"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="True"
                        FontSize="13"
                        Foreground="#E0E0E0"
                        MinHeight="280">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="Auto"/>
                  <DataGridTextColumn Header="Triggered At" Binding="{Binding TriggeredAt}" Width="2*"/>
                  <DataGridTextColumn Header="Target" Binding="{Binding TargetName}" Width="2*"/>
                  <DataGridTextColumn Header="Target Type" Binding="{Binding TargetType}" Width="Auto"/>
                  <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="2*"/>
                  <DataGridTextColumn Header="Intervention" Binding="{Binding InterventionType}" Width="Auto"/>
                  <DataGridTextColumn Header="Limit" Binding="{Binding LimitSummary}" Width="Auto"/>
                  <DataGridTextColumn Header="Snoozed" Binding="{Binding Snoozed}" Width="Auto"/>
                </DataGrid.Columns>
              </DataGrid>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1" Spacing="18">
          <Border Padding="18"
                  CornerRadius="24"
                  Background="#121926"
                  BorderBrush="#273043"
                  BorderThickness="1">
            <StackPanel Spacing="14">
              <TextBlock Text="Recent alerts" FontSize="20" FontWeight="Bold" Foreground="#F7FAFF"/>
              <TextBlock Text="The latest intervention events and the rule they came from." Foreground="#9AA8C1" TextWrapping="Wrap"/>

              <ItemsControl ItemsSource="{Binding RecentAlerts}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,10"
                            Padding="14"
                            CornerRadius="16"
                            Background="#1A2334"
                            BorderBrush="#31415C"
                            BorderThickness="1">
                      <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Text="{Binding TargetName}" Foreground="#F7FAFF" FontWeight="SemiBold"/>
                          <TextBlock Grid.Column="1" Text="{Binding TriggeredAt}" Foreground="#9AA8C1"/>
                        </Grid>
                        <TextBlock Text="{Binding InterventionType}" Foreground="#F3C779" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CategoryName}" Foreground="#D8E4F8"/>
                        <TextBlock Text="{Binding LimitSummary}" Foreground="#9AA8C1"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Border Padding="18"
                  CornerRadius="24"
                  Background="#121926"
                  BorderBrush="#273043"
                  BorderThickness="1">
            <StackPanel Spacing="12">
              <TextBlock Text="Operator notes" FontSize="20" FontWeight="Bold" Foreground="#F7FAFF"/>
              <TextBlock Text="Use category thresholds for broad behavior limits and app thresholds when a single process needs stricter handling."
                         Foreground="#9AA8C1"
                         TextWrapping="Wrap"/>
              <TextBlock Text="If alerts are firing too often, lower the intervention severity first before increasing the monitoring interval in Settings."
                         Foreground="#9AA8C1"
                         TextWrapping="Wrap"/>
              <TextBlock Text="Recent snoozes are useful feedback: repeated snoozes usually mean the configured limit is too aggressive."
                         Foreground="#9AA8C1"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
