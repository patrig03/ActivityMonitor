<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ActivityMonitor.ViewModels"
             x:Class="ActivityMonitor.Views.MainView"
             x:DataType="vm:MainViewModel">

  <Grid ColumnDefinitions="240,*"
        RowDefinitions="*"
        Background="#111318">

    <!-- ========= SIDE NAVIGATION ========= -->
    <Border Background="#0E1014" Grid.RowSpan="2">
      <StackPanel Margin="16" Spacing="18">
        <TextBlock Text="Activity Monitor"
                   FontWeight="Bold"
                   FontSize="18"
                   Foreground="#EAF1FF"/>

        <Separator/>

        <Button Content="Dashboard"
                CornerRadius="6"
                Background="#1F6FEB"
                Foreground="White"
                Padding="10"
                HorizontalAlignment="Stretch"/>

        <Button Content="Reports"
                CornerRadius="6"
                Background="Transparent"
                Foreground="#EAEFF7"
                Padding="10"
                HorizontalAlignment="Stretch"/>

        <Button Content="Settings"
                CornerRadius="6"
                Background="Transparent"
                Foreground="#EAEFF7"
                Padding="10"
                HorizontalAlignment="Stretch"/>

        <Button Content="Focus Modes"
                CornerRadius="6"
                Background="Transparent"
                Foreground="#EAEFF7"
                Padding="10"
                HorizontalAlignment="Stretch"/>

        <StackPanel Margin="0,20,0,0">
          <TextBlock Text="Status"
                     Foreground="#AAB3C6"
                     FontSize="13"/>
          <Border Background="#17202D"
                  CornerRadius="8"
                  Margin="0,6,0,0"
                  Padding="10">
            <TextBlock Text="Monitoring Active"
                       Foreground="#6DFF9C"
                       FontWeight="SemiBold"/>
          </Border>
        </StackPanel>
      </StackPanel>
    </Border>


    <!-- ========= MAIN DASHBOARD CONTENT ========= -->
    <Grid Grid.Column="1"
          RowDefinitions="Auto, Auto, *"
          Margin="18">

      <!-- HEADER -->
      <DockPanel>
        <TextBlock Text="Dashboard"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#EAF1FF"
                   DockPanel.Dock="Left"/>

        <StackPanel Orientation="Horizontal"
                    Spacing="10"
                    DockPanel.Dock="Right">
          <Button Content="Switch Theme"
                  CornerRadius="20"
                  Background="#1F6FEB"
                  Foreground="White"
                  Padding="10,4"/>

          <Button Content="Notifications"
                  CornerRadius="20"
                  Background="#17202D"
                  Foreground="#EAF1FF"
                  Padding="10,4"/>
        </StackPanel>
      </DockPanel>


      <!-- SUMMARY CARDS -->
      <UniformGrid Columns="3"
                   Margin="0,20,0,10">

        <Border Background="#1A2533"
                CornerRadius="12"
                Padding="16">
          <StackPanel>
            <TextBlock Text="Total Usage Today"
                       Foreground="#9BAACB"
                       FontSize="13"/>
            <TextBlock Text="{Binding TotalUsage}"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"/>
          </StackPanel>
        </Border>

        <Border Background="#1A2533"
                CornerRadius="12"
                Padding="16">
          <StackPanel>
            <TextBlock Text="Focus Score"
                       Foreground="#9BAACB"
                       FontSize="13"/>
            <TextBlock Text="{Binding FocusScore}"
                       Foreground="#6DFF9C"
                       FontSize="26"
                       FontWeight="Bold"/>
          </StackPanel>
        </Border>

        <Border Background="#1A2533"
                CornerRadius="12"
                Padding="16">
          <StackPanel>
            <TextBlock Text="Top App"
                       Foreground="#9BAACB"
                       FontSize="13"/>
            <TextBlock Text="{Binding TopApplication}"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"/>
          </StackPanel>
        </Border>

      </UniformGrid>


      <!-- CHART + RECOMMENDATION -->
      <Grid RowDefinitions="*"
            ColumnDefinitions="2*,*"
            Grid.Row="2">

        <!-- PIE CHART PLACEHOLDER -->
        <Border Background="#1A2533"
                CornerRadius="12"
                Padding="16">
          <StackPanel>
            <TextBlock Text="Daily Activity Distribution"
                       Foreground="#EAF1FF"
                       FontSize="18"
                       FontWeight="SemiBold"/>
            <Border Background="#0E1624"
                    CornerRadius="10"
                    Margin="0,10,0,0"
                    Height="260"
                    HorizontalAlignment="Stretch">
              <TextBlock Text="[ Chart Placeholder ]"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Foreground="#6F7D96"/>
            </Border>
          </StackPanel>
        </Border>

        <!-- RECOMMENDATIONS -->
        <Border Background="#1A2533"
                CornerRadius="12"
                Padding="16">
          <StackPanel>
            <TextBlock Text="Adaptive Insights"
                       Foreground="#EAF1FF"
                       FontSize="18"
                       FontWeight="SemiBold"/>

            <ItemsControl ItemsSource="{Binding Recommendations}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="#17202D"
                          CornerRadius="8"
                          Padding="10"
                          Margin="0,8,0,0">
                    <TextBlock Text="{Binding}"
                               Foreground="#CFE3FF"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </Border>

      </Grid>

    </Grid>
  </Grid>
</UserControl>
