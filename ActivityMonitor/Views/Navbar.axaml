<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ActivityMonitor.Views.Navbar">


  <Border Padding="4,24">
    <StackPanel Margin="16,0,8,0" Spacing="8">

          
      <!-- Status Panel -->
      <Border Background="#191919"
              CornerRadius="8"
              Margin="0,0,0,24"
              Padding="16,12">
        <StackPanel Spacing="4">
          <TextBlock Text="STARE"
                     Foreground="#7C7C7C"
                     FontSize="11"
                     FontWeight="Medium"
                     LetterSpacing="0.5"/>

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Ellipse Name="StatusIndicator" Width="8" Height="8" Fill="#6DFF9C"/>
            <TextBlock Name="StatusText"
                       Text="Monitorizare activa"
                       Foreground="#EAF1FF"
                       FontWeight="SemiBold"
                       FontSize="14"/>
          </StackPanel>

          <TextBlock Name="StatusUpdateTime"
                     Text="Ultima actualizare: acum câteva secunde"
                     Foreground="#7C879C"
                     FontSize="11"
                     Margin="0,4,0,0"/>

          <!-- <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,12,0,0"> -->
            <Button Name="StartBackendButton"
                    Classes="nav-button"
                    Content="Porneste"
                    Click="BackendStatus_OnClick"
                    HorizontalAlignment="Stretch"/>
          <!-- </Grid> -->

          <TextBlock Name="StatusActionMessage"
                     IsVisible="False"
                     Foreground="#FFB366"
                     FontSize="11"
                     Margin="0,8,0,0"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </Border>
          
          
      <!-- Navigation Items -->
      <StackPanel Name="NavItems" Spacing="4">
        <!-- Mark the current item as active via a class -->
        <Button Content="Dashboard"
                Name="DashboardButton"
                Tag="Dashboard"
                Click="Button_OnClick"
                Classes="nav-button"/>

        <Button Content="Rapoarte"
                Tag="Reports"
                Click="Button_OnClick"
                Classes="nav-button"/>

        <Button Content="Browser"
                Tag="Browser"
                Click="Button_OnClick"
                Classes="nav-button"/>

        <Button Content="Interventii"
                Tag="Interventions"
                Click="Button_OnClick"
                Classes="nav-button"/>
        
        <Button Content="Setari"
                Tag="Settings"
                Click="Button_OnClick"
                Classes="nav-button"/>
      </StackPanel>
          
    </StackPanel>
  </Border>
</UserControl>
