<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="800"
             x:Class="ActivityMonitor.Views.InterventionsView"
             Background="#101010"
             Foreground="White"
             xmlns:views="using:ActivityMonitor.Views"
             x:DataType="viewModels:InterventionsViewModel">

  


  <UserControl.Styles>
    <!-- Base theme applied via Theme=... -->

  </UserControl.Styles>

  <Grid ColumnDefinitions="*" RowDefinitions="Auto *">
    <views:AddThresholdView Grid.Row="0"/>
    <views:CurrentThresholdsView Grid.Row="1"/>
  </Grid>
  
</UserControl>
