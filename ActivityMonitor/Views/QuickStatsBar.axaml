<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:ActivityMonitor.ViewModels"
             x:DataType="viewModels:DashboardViewModel"
             x:Class="ActivityMonitor.Views.QuickStatsBar">

  <Border CornerRadius="24"
          Padding="20"
          Background="#111828"
          BorderBrush="#263146"
          BorderThickness="1">
    <WrapPanel Orientation="Horizontal"
               HorizontalAlignment="Stretch">

      <Border Width="210"
              Margin="0,0,14,14"
              CornerRadius="18"
              Background="#172033"
              BorderBrush="#2B3953"
              BorderThickness="1"
              Padding="16">
        <StackPanel Spacing="6">
          <TextBlock Text="Timp monitorizat" Foreground="#8EA0C3" FontSize="12"/>
          <TextBlock Text="{Binding TotalUsage}" Foreground="#F4F7FF" FontSize="24" FontWeight="Bold"/>
          <TextBlock Text="Timp activ in toate categoriile capturate." Foreground="#7386A8" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <Border Width="210"
              Margin="0,0,14,14"
              CornerRadius="18"
              Background="#172033"
              BorderBrush="#2B3953"
              BorderThickness="1"
              Padding="16">
        <StackPanel Spacing="6">
          <TextBlock Text="Sesiuni" Foreground="#8EA0C3" FontSize="12"/>
          <TextBlock Text="{Binding TotalSessions}" Foreground="#F4F7FF" FontSize="24" FontWeight="Bold"/>
          <TextBlock Text="Sesiuni distincte de aplicatii capturate pentru fereastra curenta de raportare." Foreground="#7386A8" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <Border Width="210"
              Margin="0,0,14,14"
              CornerRadius="18"
              Background="#172033"
              BorderBrush="#2B3953"
              BorderThickness="1"
              Padding="16">
        <StackPanel Spacing="6">
          <TextBlock Text="Sesiune medie" Foreground="#8EA0C3" FontSize="12"/>
          <TextBlock Text="{Binding AverageSession}" Foreground="#F4F7FF" FontSize="24" FontWeight="Bold"/>
          <TextBlock Text="Util pentru a observa perioade lungi fara schimbare de context." Foreground="#7386A8" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <Border Width="210"
              Margin="0,0,14,14"
              CornerRadius="18"
              Background="#172033"
              BorderBrush="#2B3953"
              BorderThickness="1"
              Padding="16">
        <StackPanel Spacing="6">
          <TextBlock Text="Scor de concentrare" Foreground="#8EA0C3" FontSize="12"/>
          <TextBlock Text="{Binding FocusScore}" Foreground="#8BFFB1" FontSize="24" FontWeight="Bold"/>
          <TextBlock Text="Ponderea timpului petrecut in categorii orientate spre munca." Foreground="#7386A8" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <Border Width="210"
              Margin="0,0,14,14"
              CornerRadius="18"
              Background="#172033"
              BorderBrush="#2B3953"
              BorderThickness="1"
              Padding="16">
        <StackPanel Spacing="6">
          <TextBlock Text="Aplicatie principala" Foreground="#8EA0C3" FontSize="12"/>
          <TextBlock Text="{Binding TopApplication}" Foreground="#7DD3FC" FontSize="24" FontWeight="Bold" TextWrapping="Wrap"/>
          <TextBlock Text="Procesul care consuma cel mai mult timp de activitate monitorizat." Foreground="#7386A8" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <Border Width="210"
              Margin="0,0,0,14"
              CornerRadius="18"
              Background="#172033"
              BorderBrush="#2B3953"
              BorderThickness="1"
              Padding="16">
        <StackPanel Spacing="6">
          <TextBlock Text="Puls interventii" Foreground="#8EA0C3" FontSize="12"/>
          <TextBlock Text="{Binding InterventionPulse}" Foreground="#FBBF24" FontSize="24" FontWeight="Bold" TextWrapping="Wrap"/>
          <TextBlock Text="Activitate recenta a pragurilor, utila pentru ajustarea limitelor." Foreground="#7386A8" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

    </WrapPanel>
  </Border>
</UserControl>
