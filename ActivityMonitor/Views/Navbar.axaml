<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ActivityMonitor.Views.Navbar">


  <!-- ========= SIDE NAVIGATION ========= -->
  <Border Padding="4,24,4,24">
    <StackPanel Margin="16,0,8,0" Spacing="8">

          
      <!-- Status Panel -->
      <Border Background="#191919"
              CornerRadius="8"
              Margin="0,0,0,24"
              Padding="16,12">
        <StackPanel Spacing="4">
          <TextBlock Text="STATUS"
                     Foreground="#7C7C7C"
                     FontSize="11"
                     FontWeight="Medium"
                     LetterSpacing="0.5"/>

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Ellipse Width="8" Height="8" Fill="#6DFF9C"/>
            <TextBlock Text="Monitoring Active"
                       Foreground="#EAF1FF"
                       FontWeight="SemiBold"
                       FontSize="14"/>
          </StackPanel>

          <TextBlock Text="Last updated: 2 min ago"
                     Foreground="#7C879C"
                     FontSize="11"
                     Margin="0,4,0,0"/>
        </StackPanel>
      </Border>
          
          
      <!-- Navigation Items -->
      <StackPanel Name="NavItems" Spacing="4">
        <!-- Mark the current item as active via a class -->
        <Button Content="Dashboard"
                Click="Button_OnClick"
                Classes="nav-button button--active"/>

        <Button Content="Reports"
                Click="Button_OnClick"
                Classes="nav-button"/>

        <Button Content="Interventions"
                Click="Button_OnClick"
                Classes="nav-button"/>
        
        <Button Content="Settings"
                Click="Button_OnClick"
                Classes="nav-button"/>
      </StackPanel>
          
    </StackPanel>
  </Border>
</UserControl>